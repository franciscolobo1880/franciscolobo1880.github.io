\begin_inset Formula 
\begin{align*}
\boldsymbol{\Sigma}_{i}= & \left(\begin{array}{cc}
\sum_{s}V^{is}\left(\rho_{s\uparrow\uparrow}^{\text{\text{ee}}}+\rho_{s\downarrow\downarrow}^{\text{\text{ee}}}\right)\mathds{1}-V^{i}\boldsymbol{\rho}_{i}^{\text{\text{ee}}} & V^{i}\boldsymbol{\rho}_{i}^{\text{eh}}\\
\left[V^{i}\boldsymbol{\rho}_{i}^{\text{eh}}\right]^{T} & -\sigma_{y}\left[\sum_{s}V^{is}\left(\rho_{s\uparrow s\uparrow}^{\text{\text{ee}}}+\rho_{s\downarrow s\downarrow}^{\text{\text{ee}}}\right)\mathds{1}-V^{i}\boldsymbol{\rho}_{i}^{\text{\text{ee}}}\right]^{T}\sigma_{y}
\end{array}\right)\\
= & \frac{1}{2}\sum_{s}V^{is}\text{Tr}\left(\tau_{z}\tilde{\boldsymbol{\rho}}_{s}\right)\left(\begin{array}{cc}
\mathds{1}\\
 & -\mathds{1}
\end{array}\right)-V^{i}\left(\begin{array}{cc}
\boldsymbol{\rho}_{i}^{\text{\text{ee}}} & -\boldsymbol{\rho}_{i}^{\text{eh}}\\
-\boldsymbol{\rho}_{i}^{\text{eh}} & -\sigma_{y}\boldsymbol{\rho}_{i}^{\text{\text{ee}}}\sigma_{y}
\end{array}\right)\\
= & \frac{1}{2}\sum_{s}V^{is}\text{Tr}\left(\tau_{z}\tilde{\boldsymbol{\rho}}_{s}\right)\left[\tau_{z}\otimes\sigma_{0}\right]-V^{i}\tilde{\boldsymbol{\rho}}_{i}
\end{align*}

\end_inset

where the trace reads as 
\begin_inset Formula 
\[
\text{Tr}\left(\tau_{z}\bar{\boldsymbol{\rho}}_{s}\right)=\text{Tr}\left(\begin{array}{cc|cc}
\rho_{s\uparrow\uparrow}^{\text{ee}} & \rho_{s\uparrow\downarrow}^{\text{ee}} & -\rho_{s\uparrow\uparrow}^{\text{eh}} & -\rho_{s\uparrow\downarrow}^{\text{eh}}\\
\rho_{s\downarrow\uparrow}^{\text{ee}} & \rho_{s\downarrow\downarrow}^{\text{ee}} & -\rho_{s\downarrow\uparrow}^{\text{eh}} & -\rho_{s\downarrow\downarrow}^{\text{eh}}\\
\hline -\left[\rho_{s\uparrow\uparrow}^{\text{he}}\right] & -\left[\rho_{s\uparrow\downarrow}^{\text{he}}\right] & -\left[-\rho_{s\uparrow\uparrow}^{\text{ee}}\right] & -\left[\rho_{s\downarrow\uparrow}^{\text{ee}}\right]\\
-\left[\rho_{s\downarrow\uparrow}^{\text{he}}\right] & -\left[\rho_{s\downarrow\downarrow}^{\text{he}}\right] & -\left[\rho_{s\uparrow\downarrow}^{\text{ee}}\right] & -\left[-\rho_{s\downarrow\downarrow}^{\text{ee}}\right]
\end{array}\right)=2\left(\rho_{s\uparrow\uparrow}^{\text{ee}}+\rho_{s\downarrow\downarrow}^{\text{ee}}\right)
\]

\end_inset


