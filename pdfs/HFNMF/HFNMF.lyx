\end_inset

Substituting Eqs.(
\begin_inset Formula $\text{\ref{eq:Hcb}}$
\end_inset

) and (
\begin_inset Formula $\text{\ref{eq:Hca}}$
\end_inset

) back into Eq.(
\begin_inset Formula $\text{\ref{eq:EM_rho}}$
\end_inset

) yields
\begin_inset Formula 
\begin{align}
-i\hbar\frac{d}{dt}\rho_{ab}^{\text{ee}} & =\rho_{a\alpha}^{\text{ee}}\bar{h}_{\alpha b}-\bar{h}_{a\alpha}\rho_{\alpha b}^{\text{ee}}\nonumber \\
 & +\frac{1}{4}\left(V_{\gamma b}^{\alpha\beta}-V_{b\gamma}^{\alpha\beta}\right)\left(\left\langle c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}c_{a}\right\rangle -\left\langle c_{\gamma}c_{\beta}^{\dagger}c_{\alpha}^{\dagger}c_{a}\right\rangle \right)\nonumber \\
 & +\frac{1}{4}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\left(\left\langle c_{b}^{\dagger}c_{\alpha}^{\dagger}c_{\beta}c_{\gamma}\right\rangle -\left\langle c_{b}^{\dagger}c_{\gamma}c_{\beta}c_{\alpha}^{\dagger}\right\rangle \right)\label{eq:r}
\end{align}

\end_inset

where we came back to the definition of the normal rDM in Eq.(
\begin_inset Formula $\text{\ref{eq:rhodef}}$
\end_inset

) for the first two terms.
 Notice, however, that the remaining interaction terms correspond to the
 expectation values of four-operators.
 For this, we introduce a mean-field approximation where we assume the two-parti
cle expectation value to simply behave as a product of two one-particle
 expectation values.
 From this mean-field decoupling we can then make use of 
\emph on
Wick's theorem
\emph default
 as done in the Appendix.
 We obtain
\begin_inset Formula 
\begin{align}
\left\langle c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}c_{\delta}\right\rangle  & \approx\mathfrak{\rho}_{\beta\alpha}^{\text{he}}\mathfrak{\rho}_{\delta\gamma}^{\text{eh}}-\rho_{\gamma\alpha}^{\text{ee}}\rho_{\delta\beta}^{\text{hh}}+\rho_{\delta\alpha}^{\text{ee}}\rho_{\gamma\beta}^{\text{ee}}\\
\left\langle c_{\alpha}c_{\beta}^{\dagger}c_{\gamma}^{\dagger}c_{\delta}\right\rangle  & \approx\rho_{\beta\alpha}^{\text{hh}}\rho_{\delta\gamma}^{\text{ee}}-\rho_{\gamma\alpha}^{\text{hh}}\rho_{\delta\beta}^{\text{ee}}+\rho_{\delta\alpha}^{\text{eh}}\rho_{\gamma\beta}^{\text{he}}\\
\left\langle c_{\alpha}^{\dagger}c_{\beta}c_{\gamma}c_{\delta}^{\dagger}\right\rangle  & \approx\rho_{\beta\alpha}^{\text{ee}}\rho_{\delta\gamma}^{\text{ee}}-\rho_{\gamma\alpha}^{\text{ee}}\rho_{\delta\beta}^{\text{hh}}+\rho_{\delta\alpha}^{\text{he}}\rho_{\gamma\beta}^{\text{eh}}
\end{align}

\end_inset

As derived below in the gray appendices, the purely electronic rDM equation
 of motion can then be written in a time-dependent Hartree-Fock in a more
 compact and elegant manner as 
\begin_inset Formula 
\begin{equation}
i\hbar\frac{d}{dt}\rho_{ab}^{\text{ee}}=\left[h_{ab}^{\text{HF}},\rho_{ab}^{\text{ee}}\right]-\rho_{ab}^{\text{ee}}\Delta_{ba}^{*}+\Delta_{ab}\rho_{ab}^{\text{he}}\label{eq:EoM_n}
\end{equation}

\end_inset

with the Hartree-Fock Hamiltonian being
\emph on

\begin_inset Formula 
\begin{equation}
h_{ab}^{\text{HF}}(\rho)=h_{ab}+\Sigma_{ab}^{\text{H}}(\rho)+\Sigma_{ab}^{\text{F}}(\rho),
\end{equation}

\end_inset


\emph default
identifying the Hartree, Fock and pairing self-energies (themselves dependent
 on the rDM) respectively as
\begin_inset Formula 
\begin{equation}
\begin{array}{c}
\Sigma_{ab}^{H}=\sum_{\gamma\delta}V_{b\gamma}^{\delta a}\rho_{\gamma\delta}^{\text{ee}}\vspace{2mm}\\
\Sigma_{ab}^{F}=-\sum_{\gamma\delta}V_{b\gamma}^{a\delta}\rho_{\gamma\delta}^{\text{ee}}
\end{array}\quad\text{and}\quad\,\Delta_{ab}=\sum_{\gamma\delta}V_{\delta\gamma}^{ab}\rho_{\gamma\delta}^{\text{eh}}
\end{equation}

\end_inset

As a side note concerning excitons, notice that the Fock self-energy term
 in is an attractive interaction (due the negative sign) such that it lower
 the total energy of the system enabling the formation of the electron-hole
 bound states.
 Conversely, the Hartree self-energy term will control details of the excitation
 spectrum, such as spin-splitting.
 Also, note the symmetry 
\begin_inset Formula $\Delta_{ab}=-\Delta_{ba}$
\end_inset

.
\end_layout

\begin_layout Standard
Analogously for the anomalous EoM we have that
\begin_inset Formula 
\begin{equation}
\frac{d}{dt}\rho_{ab}^{\text{eh}}=\left\langle \frac{i}{\hbar}[H,c_{b}]c_{a}\right\rangle -\left\langle c_{b}\frac{i}{\hbar}[H,c_{a}]\right\rangle .\label{eq:EoMan}
\end{equation}

\end_inset

but instead perform the mean-field decoupling
\begin_inset Formula 
\begin{align}
\left\langle c_{\alpha}^{\dagger}c_{\beta}c_{\gamma}c_{\delta}\right\rangle  & \approx\rho_{\beta\alpha}^{\text{ee}}\rho_{\delta\gamma}^{\text{eh}}-\rho_{\gamma\alpha}^{\text{eh}}\rho_{\delta\beta}^{\text{eh}}+\rho_{\delta\alpha}^{\text{ee}}\rho_{\gamma\beta}^{\text{eh}},\\
\left\langle c_{\alpha}c_{\beta}^{\dagger}c_{\gamma}c_{\delta}\right\rangle  & \approx\rho_{\beta\alpha}^{\text{he}}\rho_{\delta\gamma}^{\text{eh}}-\rho_{\gamma\alpha}^{\text{eh}}\rho_{\delta\beta}^{\text{ee}}+\rho_{\delta\alpha}^{\text{eh}}\rho_{\gamma\beta}^{\text{ee}}.\\
\left\langle c_{\alpha}c_{\beta}c_{\gamma}^{\dagger}c_{\delta}\right\rangle  & \approx\rho_{\beta\alpha}^{\text{eh}}\rho_{\delta\gamma}^{\text{ee}}-\rho_{\gamma\alpha}^{\text{hh}}\rho_{\delta\beta}^{\text{eh}}+\rho_{\delta\alpha}^{\text{eh}}\rho_{\gamma\beta}^{\text{hh}}\\
\left\langle c_{\alpha}c_{\beta}c_{\gamma}c_{\delta}^{\dagger}\right\rangle  & \approx\rho_{\beta\alpha}^{\text{eh}}\rho_{\delta\gamma}^{\text{hh}}-\rho_{\gamma\alpha}^{\text{eh}}\rho_{\delta\beta}^{\text{hh}}+\rho_{\delta\alpha}^{\text{hh}}\rho_{\gamma\beta}^{\text{eh}}
\end{align}

\end_inset

which yields the anomalous equation of motion
\begin_inset Formula 
\begin{equation}
i\hbar\frac{d}{dt}\rho_{ab}^{\text{eh}}=h_{ab}^{\text{HF}}\rho_{ab}^{\text{eh}}-\rho_{ab}^{\text{eh}}h_{ba}^{\text{HF}}+\Delta_{ab}\rho_{ab}^{\text{hh}}-\rho_{ab}^{\text{ee}}\Delta_{ab}\label{eq:EoM_an}
\end{equation}

\end_inset


