Notebook[{

Cell[CellGroupData[{
Cell["Zero VZ", "Subsection",
 CellChangeTimes->{{3.930821005089387*^9, 3.930821011758782*^9}, {
  3.9308220263621798`*^9, 
  3.93082202837269*^9}},ExpressionUUID->"52efc594-43a4-4e85-986a-\
16e1962811c5"],

Cell["\<\
The 2 in front comes from the two (\[PlusMinus] vF k) branches of the \
dispersion. L = N a0\
\>", "Text",
 CellChangeTimes->{{3.930821314136628*^9, 
  3.930821371451707*^9}},ExpressionUUID->"a91bf9b2-c624-4b91-9729-\
d47d86ed0b22"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{"2", 
    FractionBox[
     RowBox[{"U", " ", "a0"}], 
     RowBox[{"2", "\[Pi]", " ", "vF", " "}]], 
    FractionBox["1", 
     SqrtBox[
      RowBox[{
       SuperscriptBox["\[CapitalDelta]", "2"], "+", 
       SuperscriptBox["\[Epsilon]", "2"]}]]]}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Epsilon]", ",", 
     RowBox[{"-", "\[Epsilon]0"}], ",", "\[Epsilon]0"}], "}"}], ",", " ", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Epsilon]0", ">", "0"}], ",", 
      RowBox[{"\[CapitalDelta]", ">", "0"}]}], "}"}]}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"Normal", "[", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{"Series", "[", 
     RowBox[{"%", ",", 
      RowBox[{"{", 
       RowBox[{"\[CapitalDelta]", ",", "0", ",", "1"}], "}"}]}], "]"}], ",", 
    RowBox[{"\[Epsilon]0", ">", "0"}]}], "]"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"%", "==", "1"}], ",", "\[CapitalDelta]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"U", ">", "0"}], ",", 
     RowBox[{"L", ">", "0"}], ",", 
     RowBox[{"vF", ">", "0"}], ",", " ", 
     RowBox[{"a0", ">", "0"}]}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.930817724663761*^9, 3.930817900423223*^9}, {
   3.930817941286796*^9, 3.9308180508828487`*^9}, {3.930818106977871*^9, 
   3.930818148003908*^9}, {3.9308182713222933`*^9, 3.930818281543132*^9}, {
   3.930818330098156*^9, 3.930818380666494*^9}, {3.930820227040389*^9, 
   3.930820258250043*^9}, 3.9308213098765388`*^9, {3.930822134502137*^9, 
   3.9308221522318707`*^9}, 3.930822196922842*^9, {3.93082364099898*^9, 
   3.93082367056256*^9}, {3.9313413753443527`*^9, 3.931341383691845*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"026ccbc3-44b6-445e-b09e-4bfe820c16c2"],

Cell[BoxData[
 FractionBox[
  RowBox[{"a0", " ", "U", " ", 
   RowBox[{"Log", "[", 
    RowBox[{"1", "+", 
     FractionBox[
      RowBox[{"2", " ", "\[Epsilon]0", " ", 
       RowBox[{"(", 
        RowBox[{"\[Epsilon]0", "+", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["\[CapitalDelta]", "2"], "+", 
           SuperscriptBox["\[Epsilon]0", "2"]}]]}], ")"}]}], 
      SuperscriptBox["\[CapitalDelta]", "2"]]}], "]"}]}], 
  RowBox[{"\[Pi]", " ", "vF"}]]], "Output",
 CellChangeTimes->{{3.930818020568341*^9, 3.930818051866967*^9}, {
   3.9308181150931163`*^9, 3.930818150624548*^9}, 3.93081828273228*^9, {
   3.9308183352947483`*^9, 3.9308183480477247`*^9}, 3.930818383077841*^9, 
   3.930820259342791*^9, 3.93082135569167*^9, {3.930823647754536*^9, 
   3.930823673324461*^9}, 3.930825425370208*^9, 3.931341387473755*^9},
 CellLabel->"Out[1]=",ExpressionUUID->"47a35d96-cede-433d-8724-1ae5913fe731"],

Cell[BoxData[
 FractionBox[
  RowBox[{"a0", " ", "U", " ", 
   RowBox[{"Log", "[", 
    FractionBox[
     RowBox[{"4", " ", 
      SuperscriptBox["\[Epsilon]0", "2"]}], 
     SuperscriptBox["\[CapitalDelta]", "2"]], "]"}]}], 
  RowBox[{"\[Pi]", " ", "vF"}]]], "Output",
 CellChangeTimes->{{3.930818020568341*^9, 3.930818051866967*^9}, {
   3.9308181150931163`*^9, 3.930818150624548*^9}, 3.93081828273228*^9, {
   3.9308183352947483`*^9, 3.9308183480477247`*^9}, 3.930818383077841*^9, 
   3.930820259342791*^9, 3.93082135569167*^9, {3.930823647754536*^9, 
   3.930823673324461*^9}, 3.930825425370208*^9, 3.9313413877161493`*^9},
 CellLabel->"Out[2]=",ExpressionUUID->"a5ddd471-bc34-43cf-87b5-630883f9f022"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[CapitalDelta]", "\[Rule]", 
     RowBox[{
      RowBox[{"-", "2"}], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"-", 
        FractionBox[
         RowBox[{"\[Pi]", " ", "vF"}], 
         RowBox[{"2", " ", "a0", " ", "U"}]]}]], " ", "\[Epsilon]0"}]}], 
    "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[CapitalDelta]", "\[Rule]", 
     RowBox[{"2", " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"-", 
        FractionBox[
         RowBox[{"\[Pi]", " ", "vF"}], 
         RowBox[{"2", " ", "a0", " ", "U"}]]}]], " ", "\[Epsilon]0"}]}], 
    "}"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.930818020568341*^9, 3.930818051866967*^9}, {
   3.9308181150931163`*^9, 3.930818150624548*^9}, 3.93081828273228*^9, {
   3.9308183352947483`*^9, 3.9308183480477247`*^9}, 3.930818383077841*^9, 
   3.930820259342791*^9, 3.93082135569167*^9, {3.930823647754536*^9, 
   3.930823673324461*^9}, 3.930825425370208*^9, 3.931341387736615*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"e4cc0320-3cc6-41d2-b425-ce1a26dca470"]
}, Open  ]],

Cell[CellGroupData[{

Cell["A more exact dispersion cannot be integrated", "Subsubsection",
 CellChangeTimes->{{3.9308210216732073`*^9, 
  3.9308210475811443`*^9}},ExpressionUUID->"86633e9e-b7b7-4108-a8d5-\
9ea8ef55ffcf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{"2", 
    FractionBox[
     RowBox[{"U", " ", 
      SuperscriptBox["a0", "2"]}], 
     RowBox[{"2", "\[Pi]", " ", "L"}]], 
    FractionBox["1", 
     SqrtBox[
      RowBox[{
       SuperscriptBox["\[CapitalDelta]", "2"], "+", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "t", " ", 
           RowBox[{"Cos", "[", "ka", "]"}]}], "-", "\[Mu]"}], ")"}], 
        "2"]}]]]}], ",", 
   RowBox[{"{", 
    RowBox[{"ka", ",", 
     RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", " ", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Mu]", ">", "0"}], ",", 
      RowBox[{"t", ">", "0"}]}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.930818943829043*^9, 3.930819015768143*^9}, 
   3.93081906538144*^9, {3.930821378679967*^9, 3.930821382052481*^9}, 
   3.931341478515733*^9},ExpressionUUID->"72d8d5ca-6678-4d3f-8db4-\
f2027bc3bdf2"],

Cell[BoxData["$Aborted"], "Output",
 CellChangeTimes->{3.930819003581229*^9, 3.930819375206298*^9},
 CellLabel->
  "Out[561]=",ExpressionUUID->"dce59945-6080-4d19-a4a5-cc23ed61451a"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Finite VZ", "Subsection",
 CellChangeTimes->{{3.930821979119952*^9, 
  3.930821982316415*^9}},ExpressionUUID->"ea284da0-3b84-4b17-8c87-\
a9b81e118db3"],

Cell[CellGroupData[{

Cell["Changing variables from vk to Ek", "Subsubsection",
 CellChangeTimes->{{3.9308210536691113`*^9, 
  3.930821064680725*^9}},ExpressionUUID->"5cf2056f-60d1-4e71-b945-\
426f7cd65248"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{
    FractionBox["1", 
     RowBox[{"D", "[", 
      RowBox[{
       SqrtBox[
        RowBox[{
         SuperscriptBox["\[CapitalDelta]", "2"], "+", 
         SuperscriptBox["vk", "2"]}]], ",", "vk"}], "]"}]], "/.", 
    RowBox[{"vk", "->", 
     SqrtBox[
      RowBox[{
       SuperscriptBox["Ek", "2"], "-", 
       SuperscriptBox["\[CapitalDelta]", "2"]}]]}]}], ",", 
   RowBox[{"Ek", ">", "0"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.930819545512814*^9, 3.930819597905282*^9}},
 CellLabel->
  "In[567]:=",ExpressionUUID->"7396664b-c4a2-4f30-a470-db17d4608830"],

Cell[BoxData[
 FractionBox["Ek", 
  SqrtBox[
   RowBox[{
    SuperscriptBox["Ek", "2"], "-", 
    SuperscriptBox["\[CapitalDelta]", "2"]}]]]], "Output",
 CellChangeTimes->{{3.930819550408373*^9, 3.930819598310865*^9}},
 CellLabel->
  "Out[567]=",ExpressionUUID->"c400233b-7cf1-4eb8-ae09-a7dd895d998b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"tanh0", "[", "x_", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"2", 
     RowBox[{"UnitStep", "[", "x", "]"}]}], "-", "1"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{"tanh0", "[", 
       RowBox[{"Vz", "+", "Ek"}], "]"}], "-", 
      RowBox[{"tanh0", "[", 
       RowBox[{"Vz", "-", "Ek"}], "]"}]}], "2"], "/.", 
    RowBox[{"Vz", "->", "0.3"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"Ek", ",", 
     RowBox[{"-", "4"}], ",", "4"}], "}"}]}], "]"}]}], "Input",
