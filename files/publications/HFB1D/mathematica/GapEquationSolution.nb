Cell[TextData[{
 "The integrand is ",
 Cell[BoxData[
  RowBox[{"2", 
   FractionBox[
    RowBox[{"U", " ", 
     SuperscriptBox["a0", "2"]}], 
    RowBox[{"2", "\[Pi]", " ", "vF", " ", "L"}]], 
   FractionBox["Ek", 
    SqrtBox[
     RowBox[{
      SuperscriptBox["Ek", "2"], "-", 
      SuperscriptBox["\[CapitalDelta]", "2"]}]]], 
   FractionBox["1", "Ek"], 
   FractionBox[
    RowBox[{
     RowBox[{"tanh0", "[", 
      RowBox[{"Vz", "+", "Ek"}], "]"}], "-", 
     RowBox[{"tanh0", "[", 
      RowBox[{"Vz", "-", "Ek"}], "]"}]}], "2"]}]],
  CellChangeTimes->{{3.930819459500153*^9, 3.930819461809025*^9}, {
    3.9308195170175333`*^9, 3.930819517352394*^9}, {3.9308196097864323`*^9, 
    3.930819658051882*^9}, {3.930821080272592*^9, 3.930821169561153*^9}, {
    3.930821385947521*^9, 3.9308213891501703`*^9}, {3.930821421117895*^9, 
    3.9308214225114737`*^9}, 3.93082145834759*^9},ExpressionUUID->
  "1e68b4a3-568c-48d2-9038-65ba182bb949"],
 "\nThe integral extends from Emin = max(\[CapitalDelta],|VZ|) to \
~\[Epsilon]0\nThe extra factor 2 comes from the two solutions of \[Epsilon] \
for each Ek"
}], "Text",
 CellChangeTimes->{{3.930821529128332*^9, 3.930821548016211*^9}, {
  3.9308242331388607`*^9, 3.93082427308596*^9}, {3.930825328012486*^9, 
