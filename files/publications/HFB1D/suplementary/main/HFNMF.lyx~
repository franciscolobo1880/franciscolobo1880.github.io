\begin_layout Subsection
Zero temperature approximations
\end_layout

\begin_layout Standard
Within the zero temperature regime 
\begin_inset Formula $T\rightarrow0K$
\end_inset

 one can roughly approximate
\begin_inset Formula 
\[
\delta V_{\text{Z}}\overset{T\rightarrow0}{\longrightarrow}-\frac{U}{4N}\sum_{k}1
\]

\end_inset

Moreover, noting that 
\begin_inset Formula $\tanh(x\rightarrow\infty)\approx1-2\chi+\mathcal{O}(\chi^{2})$
\end_inset

 with 
\begin_inset Formula $\chi(x\rightarrow\infty)=e^{-2x}\approx0$
\end_inset

 and consequently 
\begin_inset Formula 
\[
\tanh(x+y)-\tanh(x-y)\approx\frac{2}{e^{2(x-y)}+1}
\]

\end_inset

the other self-consistent equations in this zero temperature regime read
 as 
\begin_inset Formula 
\begin{align*}
\Delta\approx & -U\sum_{k}\frac{\Delta}{2\tilde{E}_{k}}f\left(\tilde{V}_{\text{Z}}-\tilde{E}_{k}\right),\\
\delta\mu\approx & \frac{U}{4}+\frac{U}{4N}\sum_{k}\frac{\tilde{\epsilon}_{k}}{\tilde{E}_{k}}f\left(\tilde{V}_{\text{Z}}-\tilde{E}_{k}\right).
\end{align*}

\end_inset


