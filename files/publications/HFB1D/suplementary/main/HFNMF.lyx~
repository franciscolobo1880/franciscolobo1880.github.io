\begin_layout Standard
Furthermore, consider now the approximation where the orbitals are ultra-localiz
ed (known as Wannier orbitals) such that the interaction potential, written
 in terms of an arbitrary electronic basis 
\begin_inset Formula $\left\{ \phi_{\alpha}(\mathbf{r})\right\} $
\end_inset

, approximates to
\begin_inset Formula 
\begin{equation}
V_{\gamma\delta}^{\alpha\beta}=\int d\mathbf{r}d\mathbf{r}^{\prime}\phi_{\alpha}^{*}(\mathbf{r})\phi_{\beta}^{*}(\mathbf{r}^{\prime})V(\mathbf{r}-\mathbf{r}^{\prime})\phi_{\gamma}(\mathbf{r}^{\prime})\phi_{\delta}(\mathbf{r})\approx V^{\alpha\beta}\delta_{\alpha\delta}\delta_{\beta\gamma}
\end{equation}

\end_inset

with 
\begin_inset Formula $V^{\alpha\beta}\equiv V(\mathbf{r}_{\alpha}-\mathbf{r}_{\beta})$
\end_inset

.
 Within the scope of this approximation the interaction Hamiltonian will
 becomes simply 
\begin_inset Formula $H_{\text{int}}=\frac{1}{2}\sum_{\alpha\beta}V^{\alpha\beta}c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\beta}c_{\alpha}$
\end_inset

.
 The Hartree and Fock self-energies become
\begin_inset Formula 
\begin{equation}
\begin{array}{c}
\Sigma_{ab}^{H}=\sum_{\gamma}V^{a\gamma}\rho_{\gamma\gamma}^{\text{\text{ee}}}\delta_{ab}\vspace{2mm}\\
\Sigma_{ab}^{F}=-V^{ab}\rho_{ab}^{\text{ee}}
\end{array}\quad\text{and}\quad\,\Sigma_{ab}^{\Delta}=V^{ab}\rho_{ab}^{\text{\text{eh}}}
\end{equation}

\end_inset

Furthermore, for the sake of getting the problem in a tight-binding scheme,
 we isolate the degrees of freedom into purely spatial and spin indices
 
\begin_inset Formula $a\rightarrow i\sigma_{i}$
\end_inset

 such that 
\begin_inset Formula $\boldsymbol{\check{c}}_{i}=(c_{i\uparrow}\,\,c_{i\downarrow}\,\,c_{i\uparrow}^{\dagger}\,\,c_{i\downarrow}^{\dagger})$
\end_inset

 and 
\begin_inset Formula 
\begin{equation}
\boldsymbol{\rho}_{ij}=\left(\begin{array}{cc}
\boldsymbol{\rho}_{ij}^{\text{\text{ee}}} & \boldsymbol{\rho}_{ij}^{\text{eh}}\\
\boldsymbol{\rho}_{ji}^{\text{he}} & \boldsymbol{\rho}_{ji}^{\text{\text{hh}}}
\end{array}\right)=\left(\begin{array}{cc|cc}
\rho_{i\uparrow j\uparrow}^{\text{ee}} & \rho_{i\uparrow j\downarrow}^{\text{ee}} & \rho_{i\uparrow j\uparrow}^{\text{eh}} & \rho_{i\uparrow j\downarrow}^{\text{eh}}\\
\rho_{i\downarrow j\uparrow}^{\text{ee}} & \rho_{i\downarrow j\downarrow}^{\text{ee}} & \rho_{i\downarrow j\uparrow}^{\text{eh}} & \rho_{i\downarrow j\downarrow}^{\text{eh}}\\
\hline \rho_{i\uparrow j\uparrow}^{\text{he}} & \rho_{i\uparrow j\downarrow}^{\text{he}} & \rho_{i\uparrow j\uparrow}^{\text{hh}} & \rho_{i\downarrow j\uparrow}^{\text{hh}}\\
\rho_{i\downarrow j\uparrow}^{\text{he}} & \rho_{i\downarrow j\downarrow}^{\text{he}} & \rho_{i\uparrow j\downarrow}^{\text{hh}} & \rho_{i\downarrow j\downarrow}^{\text{hh}}
\end{array}\right)
\end{equation}

\end_inset

Note the use of the bold to denote that an object possesses a spin structure.
 Moreover, notice that, since we considered the interaction to be spin-independe
nt, we also have that 
\begin_inset Formula $V^{i\sigma_{i}j\sigma_{j}}\equiv V^{ij}$
\end_inset

.
 In this basis, the self-energies read as
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align}
\Sigma_{i\sigma_{i}j\sigma_{j}}^{H}= & \sum_{\ell}V^{i\ell}\left(\rho_{\ell\uparrow\ell\uparrow}^{\text{\text{ee}}}+\rho_{\ell\downarrow\ell\downarrow}^{\text{\text{ee}}}\right)\delta_{ij}\delta_{\sigma_{i}\sigma_{j}},\\
\Sigma_{i\sigma_{i}j\sigma_{j}}^{F}= & -V^{ij}\rho_{i\sigma_{i}j\sigma_{j}}^{\text{ee}}\text{ and }\,\Sigma_{i\sigma_{i}j\sigma_{j}}^{\Delta}=V^{ij}\rho_{i\sigma_{i}j\sigma_{j}}^{\text{eh}},\nonumber 
