\series default

\begin_inset Formula 
\begin{align*}
\boldsymbol{\rho}_{ij} & =\frac{1}{N}\sum_{k}\langle\check{\boldsymbol{c}}_{k}^{\dagger}\otimes\check{\boldsymbol{c}}_{k}\rangle e^{\textcolor{red}{i}k(x_{j}-x_{i})}\\
\Rightarrow\rho_{i\uparrow i\downarrow}^{\text{eh}} & =\frac{1}{N}\sum_{k}\langle c_{k\downarrow}c_{k\uparrow}\rangle e^{\textcolor{red}{i}k(x_{i}-x_{i})}\\
 & =\frac{1}{N}\sum_{k}\left\langle \left(v_{k}\gamma_{k\downarrow}+u_{k}^{*}\gamma_{-k\uparrow}^{\dagger}\right)\left(v_{k}\gamma_{k\uparrow}+u_{k}^{*}\gamma_{-k\downarrow}^{\dagger}\right)\right\rangle \\
 & =\frac{1}{N}\sum_{k}v_{k}v_{k}\langle\gamma_{k\downarrow}\gamma_{k\uparrow}\rangle+v_{k}u_{k}^{*}\langle\gamma_{k\downarrow}\gamma_{-k\downarrow}^{\dagger}\rangle+u_{k}^{*}v_{k}\langle\gamma_{-k\uparrow}^{\dagger}\gamma_{k\uparrow}\rangle+u_{k}^{*}u_{k}^{*}\langle\gamma_{-k\uparrow}^{\dagger}\gamma_{-k\downarrow}^{\dagger}\rangle\\
