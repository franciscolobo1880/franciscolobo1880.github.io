\begin_inset Argument 1
status open

\begin_layout Plain Layout
colback=black!5!white, colframe=black!5!white, breakable
\end_layout

\end_inset


\end_layout

\begin_layout Plain Layout
\begin_inset Formula $\text{\textbf{Eigenvectors expressions:} }v_{k}/u_{k}=\left(-\frac{-\tilde{\epsilon}_{k}\pm\sqrt{\tilde{\epsilon}_{k}^{2}+\Delta^{2}}}{\Delta},1\right)$
\end_inset


\end_layout

\end_inset

Specifically we have that
\begin_inset Formula 
\begin{align}
\mathcal{H}(k) & =\frac{1}{2}\left(\begin{array}{cc}
c^{\dagger} & c\end{array}\right)\boldsymbol{H}\left(\begin{array}{c}
c\\
c^{\dagger}
\end{array}\right)=\frac{1}{2}\left(\begin{array}{cc}
\gamma^{\dagger} & \gamma\end{array}\right)\boldsymbol{\mathcal{E}}\left(\begin{array}{c}
\gamma\\
\gamma^{\dagger}
\end{array}\right)=E_{0}+\sum_{k}\left(-E_{k}\right)\gamma_{k}^{\dagger}\gamma_{k}
\end{align}

\end_inset

with 
\begin_inset Formula $E_{0}=\frac{1}{2}\sum_{k}E_{k}$
\end_inset

 the ground state energy.
 Note that the energies 
\begin_inset Formula $\tilde{\epsilon}_{k}$
\end_inset

 and 
\begin_inset Formula $\tilde{V}_{\text{Z}}$
\end_inset

 have now a tilde; this notation indicates that the quantities are dressed,
 already accounting for the 
\begin_inset Formula $U$
\end_inset

-induced shifts, i.e 
\begin_inset Formula $\tilde{\epsilon}_{k}=\epsilon_{k}-\tilde{\mu}$
\end_inset

, 
\begin_inset Formula $\tilde{\mu}=\mu+\delta\mu$
\end_inset

 and 
\begin_inset Formula $\tilde{V}_{\text{Z}}=V_{\text{Z}}+\delta V_{\text{Z}}$
\end_inset

.
 The superconductive correlation then reads as
\begin_inset Formula 
\begin{equation}
\rho_{\uparrow\downarrow}^{\text{eh}}=\frac{1}{N}\sum_{k}\left[u_{k+}^{*}v_{k+}f(E_{k+})+u_{k-}^{*}v_{k-}f(E_{k-})\right]\label{eq:rho_uv}
\end{equation}

\end_inset

with 
\begin_inset Formula $f$
\end_inset

 is the Fermi-Dirac distribution.
