\begin_layout Standard
According to Pablo's calculation, the self-consistent gap equation with
 Zeeman reads as
\begin_inset Formula 
\begin{align*}
\Delta= & -U\sum_{k}\frac{\Delta}{4\tilde{E}_{k}}\left[\tanh\left(\frac{\tilde{V}_{\text{Z}}+\tilde{E}_{k}}{2k_{B}T}\right)-\tanh\left(\frac{\tilde{V}_{\text{Z}}-\tilde{E}_{k}}{2k_{B}T}\right)\right]
\end{align*}

\end_inset

where the tilded quantities are dressed, already accounting for the 
\begin_inset Formula $U$
\end_inset

-induced shifts, i.e 
\begin_inset Formula $\tilde{\mu}=\mu-\delta\mu$
\end_inset

 and 
\begin_inset Formula $\tilde{V}_{\text{Z}}=V_{\text{Z}}+\delta V_{\text{Z}}$
\end_inset

, and 
\begin_inset Formula $E_{k}$
\end_inset

 the eigenenergies given by 
\begin_inset Formula $\tilde{E}_{k}=\sqrt{\Delta^{2}+\tilde{\epsilon}_{k}^{2}}$
\end_inset

 with 
\begin_inset Formula $\tilde{\epsilon}_{k}=\epsilon_{k}-\tilde{\mu}$
\end_inset

.
 Furthermore, the self-consistent equation for the induced Zeeman 
\begin_inset Formula $\delta V_{\text{Z}}$
\end_inset

 and chemical potential 
\begin_inset Formula $\delta\mu$
\end_inset

 are
\begin_inset Formula 
\begin{align*}
\delta\mu= & \frac{U}{4}+\frac{U}{4N}\sum_{k}\frac{\tilde{\epsilon}_{k}}{2\tilde{E}_{k}}\left[\tanh\left(\frac{\tilde{V}_{\text{Z}}+\tilde{E}_{k}}{2k_{B}T}\right)-\tanh\left(\frac{\tilde{V}_{\text{Z}}-\tilde{E}_{k}}{2k_{B}T}\right)\right]\\
\delta V_{\text{Z}}= & -\frac{U}{2N}\sum_{k}\frac{\sinh\left(\frac{\tilde{V}_{Z}}{k_{B}T}\right)}{\cosh\left(\frac{\tilde{V}_{Z}}{k_{B}T}\right)+\cosh\left(\frac{\tilde{E}_{k}}{k_{B}T}\right)}
\end{align*}

\end_inset

Within the zero temperature regime 
\begin_inset Formula $T\rightarrow0K$
\end_inset

 one can roughly approximate
\begin_inset Formula 
\begin{align*}
\delta V_{\text{Z}}= & -\frac{U}{2N}\sum_{k}\frac{\sinh\left(\frac{\tilde{V}_{Z}}{k_{B}T}\right)}{\cosh\left(\frac{\tilde{V}_{Z}}{k_{B}T}\right)+\cosh\left(\frac{\tilde{E}_{k}}{k_{B}T}\right)}\\
\approx & -\frac{U}{2N}\sum_{k}\frac{1}{2}\frac{\sinh\left(1/T\right)}{\cosh\left(1/T\right)}\\
= & -\frac{U}{2N}\sum_{k}\frac{1}{2}\tanh\left(1/T\right)\overset{T\rightarrow0}{\longrightarrow}-\frac{U}{4}\sum_{k}1
\end{align*}

\end_inset

Moreover, and noting that
\begin_inset Formula 
\begin{align*}
\tanh(x) & =\frac{\sinh(x)}{\cosh(x)}=\frac{e^{x}-e^{-x}}{e^{x}+e^{-x}}=\frac{1-e^{-2x}}{1+e^{-2x}}\\
 & \overset{\chi=e^{-2x}}{\longrightarrow}\frac{1-\chi}{1+\chi}\overset{\chi\overset{x\rightarrow\infty}{\longrightarrow}0}{\longrightarrow}1-2\chi+\mathcal{O}(\chi^{2})
\end{align*}

\end_inset

and thus
\begin_inset Formula 
\begin{align*}
 & \tanh(x+y)-\tanh(x-y)\\
= & \frac{\tanh(x)+\tanh(y)}{1+\tanh(x)\tanh(y)}-\frac{\tanh(x)+\tanh(-y)}{1+\tanh(x)\tanh(-y)}\\
\approx & \frac{\left(1-2\chi\right)+\left(1-2\xi\right)}{1+\left(1-2\chi\right)\left(1-2\xi\right)}-\frac{\left(1-2\chi\right)-\left(1-2\xi\right)}{1-\left(1-2\chi\right)\left(1-2\xi\right)}\\
\approx & 1+\frac{\chi-\xi}{\chi+\xi}=1+\frac{1-e^{2(x-y)}}{1+e^{2(x-y)}}=2\frac{1}{e^{2(x-y)}+1},
\end{align*}

\end_inset

the remaining self-consistent equation reads as 
\begin_inset Formula 
\begin{align*}
\Delta\approx & -U\sum_{k}\frac{\Delta}{2\tilde{E}_{k}}f\left(\tilde{V}_{\text{Z}}-\tilde{E}_{k}\right),\\
\delta\mu\approx & \frac{U}{4}+\frac{U}{4N}\sum_{k}\frac{\tilde{\epsilon}_{k}}{\tilde{E}_{k}}f\left(\tilde{V}_{\text{Z}}-\tilde{E}_{k}\right).
\end{align*}

\end_inset


