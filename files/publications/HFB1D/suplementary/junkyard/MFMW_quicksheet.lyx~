 & -\frac{1}{2}(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha})(\rho_{\alpha b}^{\text{hh}}\rho_{\gamma\beta}^{\text{eh}}-\rho_{\beta b}^{\text{eh}}\rho_{\gamma\alpha}^{\text{ee}}+\rho_{\gamma b}^{\text{eh}}\rho_{\beta\alpha}^{\text{ee}})
\end{align*}

