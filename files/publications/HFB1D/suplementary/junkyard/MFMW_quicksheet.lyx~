= & \rho_{a\gamma}^{\text{eh}}\Sigma_{b\gamma}^{\text{HF}}-\frac{1}{2}\rho_{a\alpha}^{\text{ee}}(\Delta_{\alpha b}-\Delta_{b\alpha})\\
= & \left.\rho_{\text{eh}}\cdot\Sigma_{\text{\text{HF}}}^{*}\right|_{ab}-\left.\rho_{\text{ee}}\cdot\Delta\right|_{ab}
\end{align*}

\end_inset

and the second one reading
\begin_inset Formula 
\begin{align*}
 & -\frac{1}{2}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\rho_{\gamma\beta}^{\text{eh}}\rho_{\alpha b}^{\text{hh}}+\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\rho_{\gamma\alpha}^{\text{ee}}\rho_{\beta b}^{\text{eh}}\\
= & -\frac{1}{2}\left(\Delta_{\alpha a}-\Delta_{a\alpha}\right)\rho_{\alpha b}^{\text{hh}}+\Sigma_{a\beta}^{\text{HF}}\rho_{\beta b}^{\text{eh}}\\
= & \left.\Delta\cdot\rho_{\text{hh}}\right|_{ab}+\left.\Sigma_{\text{HF}}\cdot\rho_{\text{eh}}\right|_{ab}
\end{align*}

