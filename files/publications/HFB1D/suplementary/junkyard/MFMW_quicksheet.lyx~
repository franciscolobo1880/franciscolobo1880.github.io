\end{align*}

\end_inset

(no index is a matrix since I reserve the bold specifically to denote the
 spin structure) and the anomalous terms reads
\begin_inset Formula 
\begin{align*}
 & -\frac{1}{2}\mathfrak{\rho}_{a\gamma}^{\text{eh}}(V_{b\gamma}^{\beta\alpha}-V_{\gamma b}^{\beta\alpha})(\mathfrak{\rho}_{\alpha\beta}^{\text{eh}})^{*}-\frac{1}{2}(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha})\mathfrak{\rho}_{\gamma\beta}^{\text{eh}}\mathfrak{\rho}_{\alpha b}^{\text{he}}\\
= & -\frac{1}{2}\mathfrak{\rho}_{a\gamma}^{\text{eh}}(\Delta_{b\gamma}-\Delta_{\gamma b})^{*}-\frac{1}{2}(\Delta_{\alpha a}-\Delta_{a\alpha})\mathfrak{\rho}_{\alpha b}^{\text{he}}\\
= & \left.\rho_{\text{eh}}\cdot\Delta^{*}\right|_{ab}+\left.\Delta\cdot\mathfrak{\rho}_{\text{he}}\right|_{ab}
\end{align*}

\end_inset

The non-interacting terms is trivially 
\begin_inset Formula $-[h,\rho_{\text{ee}}]|_{ab}$
\end_inset

.
 Analogously for the 
\emph on
