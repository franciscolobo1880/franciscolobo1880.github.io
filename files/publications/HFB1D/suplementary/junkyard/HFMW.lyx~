\begin_layout Subsection
Reduced density matrix equations of motion
\end_layout

\begin_layout Standard
We start by solving for the normal rDM equation of motions
\begin_inset Formula 
\begin{equation}
\frac{d}{dt}\rho_{ab}^{\text{ee}}(t)=\left\langle \frac{dc_{b}^{\dagger}(t)}{dt}c_{a}(t)\right\rangle +\left\langle c_{b}^{\dagger}(t)\frac{dc_{a}(t)}{dt}\right\rangle ,
\end{equation}

\end_inset

in the Heisenberg picture of quantum mechanics, where the fermionic operators
 evolve accordingly to the Heisenberg equation.
 Therefore the rDM equation of motion reads
\begin_inset Formula 
\begin{equation}
\frac{d}{dt}\rho_{ab}^{\text{ee}}=\left\langle \frac{i}{\hbar}[H,c_{b}^{\dagger}]c_{a}\right\rangle +\left\langle c_{b}^{\dagger}\frac{i}{\hbar}[H,c_{a}]\right\rangle .\label{eq:EM_rho}
\end{equation}

\end_inset

where we have omitted the time dependency in the fermionic operators for
 compactness.
 This practice is done throughout the remaining work with no further mention.
 As shown in Appendix, given the equal-time fermionic anti-commutator properties
 
\begin_inset Formula $\left\{ c_{a},c_{b}^{\dagger}\right\} =\left\{ c_{b}^{\dagger},c_{a}\right\} =\delta_{ab}$
\end_inset

 and 
\begin_inset Formula $\left\{ c_{a},c_{b}\right\} =\left\{ c_{b}^{\dagger},c_{a}^{\dagger}\right\} =0$
\end_inset

, each of the commutators are evaluated to
\begin_inset Formula 
\begin{align}
[H,c_{b}^{\dagger}] & =\bar{h}_{\alpha b}c_{\alpha}^{\dagger}+\frac{1}{4}\left(V_{\gamma b}^{\alpha\beta}-V_{b\gamma}^{\alpha\beta}\right)\left(c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}-c_{\gamma}c_{\beta}^{\dagger}c_{\alpha}^{\dagger}\right)\label{eq:Hcb}\\{}
[H,c_{a}] & =-\bar{h}_{a\alpha}c_{\alpha}+\frac{1}{4}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\left(c_{\alpha}^{\dagger}c_{\beta}c_{\gamma}-c_{\gamma}c_{\beta}c_{\alpha}^{\dagger}\right),\label{eq:Hca}
\end{align}

\end_inset

where we have hidden the summations on repeated indices using Einstein's
 notation.
 
