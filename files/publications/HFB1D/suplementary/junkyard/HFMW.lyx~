= & \frac{1}{4}\sum_{\alpha\beta\gamma}\left(V_{\beta\gamma}^{\gamma\alpha}-V_{\gamma\beta}^{\gamma\alpha}\right)\left(c_{\alpha}^{\dagger}c_{\beta}-c_{\beta}c_{\alpha}^{\dagger}\right)
\end{align*}

