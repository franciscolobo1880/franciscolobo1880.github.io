\begin{align*}
 & \frac{1}{4}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\rho_{\alpha b}^{\text{hh}}\rho_{\gamma\beta}^{\text{eh}}-\frac{1}{4}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\rho_{\beta b}^{\text{eh}}\rho_{\gamma\alpha}^{\text{ee}}+\frac{1}{4}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\rho_{\gamma b}^{\text{eh}}\rho_{\beta\alpha}^{\text{ee}}\\
 & -\frac{1}{4}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\rho_{\gamma b}^{\text{eh}}\rho_{\alpha\beta}^{\text{hh}}+\frac{1}{4}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\rho_{\beta b}^{\text{eh}}\rho_{\alpha\gamma}^{\text{hh}}-\frac{1}{4}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\rho_{\alpha b}^{\text{hh}}\rho_{\beta\gamma}^{\text{eh}}\\
= & \frac{1}{2}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\rho_{\gamma\beta}^{\text{eh}}\rho_{\alpha b}^{\text{hh}}+\frac{1}{2}\left(-V_{\beta\gamma}^{\alpha a}+V_{\beta\gamma}^{a\alpha}\right)\left(-\rho_{\beta\alpha}^{\text{ee}}+\delta_{\alpha\beta}\right)\rho_{\gamma b}^{\text{eh}}+\frac{1}{2}\left(-V_{\gamma\beta}^{\alpha a}+V_{\gamma\beta}^{a\alpha}\right)\rho_{\beta\alpha}^{\text{ee}}\rho_{\gamma b}^{\text{eh}}\\
= & \frac{1}{2}\left(\Delta_{\alpha a}-\Delta_{a\alpha}\right)\rho_{\alpha b}^{\text{hh}}+\frac{1}{2}\left(-\Sigma_{a\gamma}^{F}-\Sigma_{a\gamma}^{H}\right)\rho_{\gamma b}^{\text{eh}}+\mu_{a\gamma}\rho_{\gamma b}^{\text{eh}}+\frac{1}{2}\left(-\Sigma_{a\gamma}^{H}-\Sigma_{a\gamma}^{F}\right)\rho_{\gamma b}^{\text{eh}}\\
= & -\Delta_{a\alpha}\rho_{\alpha b}^{\text{hh}}-\Sigma_{a\gamma}\rho_{\gamma b}^{\text{eh}}+\mu_{a\gamma}\rho_{\gamma b}^{\text{eh}}\\
= & \left(-\boldsymbol{\Sigma}+\boldsymbol{\mu}\right)\boldsymbol{\rho}_{\text{eh}}-\boldsymbol{\Delta}\boldsymbol{\rho}_{\text{hh}}
\end{align*}

\end_inset

Putting these three terms together we obtain
\begin_inset Formula 
\begin{align*}
 & \left[\boldsymbol{\rho}_{\text{eh}}\left(-\boldsymbol{\Sigma}^{T}+\boldsymbol{\mu}^{T}\right)+\boldsymbol{\rho}_{\text{ee}}\boldsymbol{\Delta}\right]+\left[\left(-\boldsymbol{\Sigma}+\boldsymbol{\mu}\right)\boldsymbol{\rho}_{\text{eh}}-\boldsymbol{\Delta}\boldsymbol{\rho}_{\text{hh}}\right]+\left[-\boldsymbol{\rho}_{\text{eh}}\bar{\boldsymbol{h}}^{T}-\bar{\boldsymbol{h}}\boldsymbol{\rho}_{\text{eh}}\right]\\
= & -\left((\bar{\boldsymbol{h}}-\boldsymbol{\mu})+\boldsymbol{\Sigma}\right)\boldsymbol{\rho}_{\text{eh}}-\boldsymbol{\rho}_{\text{eh}}\left((\bar{\boldsymbol{h}}-\boldsymbol{\mu})+\boldsymbol{\Sigma}\right)^{T}-\boldsymbol{\Delta}\boldsymbol{\rho}_{\text{hh}}+\boldsymbol{\rho}_{\text{ee}}\boldsymbol{\Delta}\\
= & -\mathbf{H}_{\text{HF}}\boldsymbol{\rho}_{\text{eh}}-\boldsymbol{\rho}_{\text{eh}}\mathbf{H}_{\text{HF}}^{T}-\boldsymbol{\Delta}\boldsymbol{\rho}_{\text{hh}}+\boldsymbol{\rho}_{\text{ee}}\boldsymbol{\Delta}
\end{align*}

\end_inset


\end_layout

\end_inset

Finally, the complete reduced density matrix equation of motions yields
\begin_inset Formula 
\begin{equation}
i\hbar\frac{d}{dt}\boldsymbol{\rho}=\left[\mathbf{H}_{\text{BdG}},\boldsymbol{\rho}\right]
\end{equation}

\end_inset

where we rewrote this expression in terms of an effective Nambu Hamiltonian
 
\begin_inset Formula $\mathbf{H}_{\text{BdG}}$
\end_inset

 defined as
\begin_inset Formula 
\begin{equation}
\mathbf{H}_{\text{BdG}}=\left[\begin{array}{cc}
\mathbf{H}_{\text{HF}} & \boldsymbol{\Delta}\\
\boldsymbol{\Delta}^{\dagger} & -\mathbf{H}_{\text{HF}}^{T}
\end{array}\right]
\end{equation}

\end_inset

Furthermore, using the relations initially shown in Eqs.(
\begin_inset Formula $\text{\ref{eq:rDM_rel}}$
\end_inset

), one can express both the EoMs in Eq.(
\begin_inset Formula $\text{\ref{eq:EoM_n}}$
\end_inset

) and Eq.(
\begin_inset Formula $\text{\ref{eq:EoM_an}}$
\end_inset

) only in terms of the electronic normal 
\begin_inset Formula $\boldsymbol{\rho}_{\text{n}}\equiv\boldsymbol{\rho}_{\text{ee}}$
\end_inset

 and anomalous 
\begin_inset Formula $\boldsymbol{\rho}_{\text{a}}\equiv\boldsymbol{\rho}_{\text{eh}}$
\end_inset

 rDMs (instead of the four distinct terms 
\begin_inset Formula $\boldsymbol{\rho}_{\text{ee}}$
\end_inset

, 
\begin_inset Formula $\boldsymbol{\rho}_{\text{eh}}$
\end_inset

, 
\begin_inset Formula $\boldsymbol{\rho}_{\text{he}}$
\end_inset

 and 
\begin_inset Formula $\boldsymbol{\rho}_{\text{hh}}$
\end_inset

).
 We write
\begin_inset Formula 
\begin{align*}
i\hbar\frac{d}{dt}\boldsymbol{\rho}_{\text{n}}= & \left[\mathbf{H}_{\text{HF}},\boldsymbol{\rho}_{\text{n}}\right]-\left(\boldsymbol{\rho}_{\text{a}}\boldsymbol{\Delta}^{\dagger}+\left(\boldsymbol{\rho}_{\text{a}}\boldsymbol{\Delta}^{\dagger}\right)^{\dagger}\right)\\
i\hbar\frac{d}{dt}\boldsymbol{\rho}_{\text{a}}= & \mathbf{H}_{\text{HF}}\boldsymbol{\rho}_{\text{a}}+\boldsymbol{\rho}_{\text{a}}\mathbf{H}_{\text{HF}}^{T}-\left(\boldsymbol{\Delta}\boldsymbol{\rho}_{\text{n}}^{\dagger}+\boldsymbol{\rho}_{\text{n}}\boldsymbol{\Delta}\right)+\boldsymbol{\Delta}
\end{align*}

\end_inset


