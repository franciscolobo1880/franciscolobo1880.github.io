, 
\begin_inset Formula $B\equiv\Delta_{0}\Theta(-x-L)\sin\varphi$
\end_inset

, 
\begin_inset Formula $C\equiv-\eta\partial_{x}^{2}-\mu$
\end_inset

, 
\begin_inset Formula $D\equiv\alpha_{\text{R}}\partial_{x}$
\end_inset

 and 
\begin_inset Formula $E\equiv V_{\text{Z}}$
\end_inset

.
 When acting on the Nambu spinor's particle-hole and spin spaces, we obtain
 
\begin_inset Formula 
\[
A\left[\begin{array}{cc}
0 & 1\\
1 & 0
\end{array}\right]\left[\begin{array}{c}
\psi\\
\psi^{\dagger}
\end{array}\right]=A\left[\begin{array}{c}
\psi^{\dagger}\\
\psi
\end{array}\right]=A\left[\begin{array}{c}
\begin{array}{c}
\psi_{\downarrow}^{*}\\
-\psi_{\uparrow}^{*}
\end{array}\\
\begin{array}{c}
\psi_{\uparrow}\\
\psi_{\downarrow}
\end{array}
\end{array}\right],\quad B\left[\begin{array}{cc}
0 & -i\\
i & 0
\end{array}\right]\left[\begin{array}{c}
\psi\\
\psi^{\dagger}
\end{array}\right]=iB\left[\begin{array}{c}
-\psi^{\dagger}\\
\psi
\end{array}\right]=iB\left[\begin{array}{c}
\begin{array}{c}
-\psi_{\downarrow}^{*}\\
\psi_{\uparrow}^{*}
\end{array}\\
\begin{array}{c}
\psi_{\uparrow}\\
\psi_{\downarrow}
\end{array}
\end{array}\right],
\]

\end_inset


\begin_inset Formula 
\[
C\tau_{z}\Psi=C\left[\begin{array}{cc}
1 & 0\\
0 & -1
\end{array}\right]\left[\begin{array}{c}
\psi\\
\psi^{\dagger}
\end{array}\right]=C\left[\begin{array}{c}
\psi\\
-\psi^{\dagger}
\end{array}\right]=C\left[\begin{array}{c}
\begin{array}{c}
\psi_{\uparrow}\\
\psi_{\downarrow}
\end{array}\\
\begin{array}{c}
-\psi_{\downarrow}^{*}\\
\psi_{\uparrow}^{*}
\end{array}
\end{array}\right],\quad E\sigma_{x}\Psi=E\left[\begin{array}{c}
\left[\begin{array}{cc}
0 & 1\\
1 & 0
\end{array}\right]\left[\begin{array}{c}
\psi_{\uparrow}\\
\psi_{\downarrow}
\end{array}\right]\\
\left[\begin{array}{cc}
0 & 1\\
1 & 0
\end{array}\right]\left[\begin{array}{c}
\psi_{\downarrow}^{*}\\
-\psi_{\uparrow}^{*}
\end{array}\right]
\end{array}\right]=E\left[\begin{array}{c}
\psi_{\downarrow}\\
\psi_{\uparrow}\\
-\psi_{\uparrow}^{*}\\
\psi_{\downarrow}^{*}
\end{array}\right],
\]

\end_inset


\begin_inset Formula 
\[
\text{ and}\quad iD\sigma_{y}\left(\tau_{z}\Psi\right)=iD\sigma_{y}\left[\begin{array}{c}
\psi\\
-\psi^{\dagger}
\end{array}\right]=iD\left[\begin{array}{c}
\left[\begin{array}{cc}
0 & -i\\
i & 0
\end{array}\right]\left[\begin{array}{c}
\psi_{\uparrow}\\
\psi_{\downarrow}
\end{array}\right]\\
-\left[\begin{array}{cc}
0 & -i\\
i & 0
\end{array}\right]\left[\begin{array}{c}
\psi_{\downarrow}^{*}\\
-\psi_{\uparrow}^{*}
\end{array}\right]
\end{array}\right]=D\left[\begin{array}{c}
\psi_{\downarrow}\\
-\psi_{\uparrow}\\
\psi_{\uparrow}^{*}\\
\psi_{\downarrow}^{*}
\end{array}\right]
\]

\end_inset

Putting all these terms together we obtain
\begin_inset Formula 
\[
\left(\begin{array}{c}
c_{1}^{*}\psi_{\downarrow}^{*}+C\psi_{\uparrow}+c_{2}\psi_{\downarrow}\\
-c_{1}^{*}\psi_{\uparrow}^{*}+C\psi_{\downarrow}+c_{3}\psi_{\uparrow}\\
c_{1}\psi_{\uparrow}-C\psi_{\downarrow}^{*}-c_{3}\psi_{\uparrow}^{*}\\
c_{1}\psi_{\downarrow}+C\psi_{\uparrow}^{*}+c_{2}\psi_{\downarrow}^{*}
\end{array}\right)=\left(\begin{array}{cc|cc}
C & c_{2} & c_{1}^{*} & 0\\
c_{3} & C & 0 & c_{1}^{*}\\
\hline c_{1} & 0 & -C & c_{3}\\
0 & c_{1} & c_{2} & -C
\end{array}\right)\left(\begin{array}{c}
\psi_{\uparrow}\\
\psi_{\downarrow}\\
\psi_{\downarrow}^{*}\\
-\psi_{\uparrow}^{*}
\end{array}\right)\equiv\left(\begin{array}{cc}
\boldsymbol{h} & \boldsymbol{\Delta}^{*}\\
\boldsymbol{\Delta} & -\sigma_{y}\boldsymbol{h}^{*}\sigma_{y}
\end{array}\right)\left(\begin{array}{c}
\psi\\
\psi^{\dagger}
\end{array}\right)_{\square}
\]

\end_inset

where 
\begin_inset Formula $c_{1}\equiv A+iB$
\end_inset

 and 
\begin_inset Formula $c_{2/3}\equiv E\pm D$
\end_inset

.

