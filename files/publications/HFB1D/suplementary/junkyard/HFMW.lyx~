\begin{align*}
\left[c_{\alpha}^{\dagger}c_{\beta},c_{a}\right] & =c_{\alpha}^{\dagger}\cancel{\left\{ c_{\beta},c_{a}\right\} }-\left\{ c_{a},c_{\alpha}^{\dagger}\right\} c_{\beta}=-c_{\beta}\delta_{a\alpha}\\
\left[c_{\beta}c_{\alpha}^{\dagger},c_{a}\right] & =c_{\beta}\left\{ c_{\alpha}^{\dagger},c_{a}\right\} -\cancel{\left\{ c_{a},c_{\beta}\right\} }c_{\alpha}^{\dagger}=c_{\beta}\delta_{a\alpha}
\end{align*}

\end_inset

and that
\begin_inset Formula 
\begin{align*}
\left[c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}c_{\delta},c_{a}\right] & =c_{\alpha}^{\dagger}c_{\beta}^{\dagger}\left(c_{\gamma}\cancel{\left\{ c_{\delta},c_{a}\right\} }-\cancel{\left\{ c_{a},c_{\gamma}\right\} }c_{\delta}\right)+\left(c_{\alpha}^{\dagger}\left\{ c_{\beta}^{\dagger},c_{a}\right\} -\left\{ c_{a},c_{\alpha}^{\dagger}\right\} c_{\beta}^{\dagger}\right)c_{\gamma}c_{\delta}=c_{\alpha}^{\dagger}c_{\gamma}c_{\delta}\delta_{\beta a}-c_{\beta}^{\dagger}c_{\gamma}c_{\delta}\delta_{a\alpha}\\
