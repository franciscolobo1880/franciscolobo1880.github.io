 being
\begin_inset Formula 
\begin{equation}
\tilde{h}_{\alpha\beta}(t)\equiv h_{\alpha\beta}+B_{\alpha\beta}F(t)\quad\text{and}\quad\mu_{\alpha\beta}=\frac{1}{2}\sum_{\gamma}\left(V_{\beta\gamma}^{\gamma\alpha}-V_{\gamma\beta}^{\gamma\alpha}\right)
\end{equation}

\end_inset


