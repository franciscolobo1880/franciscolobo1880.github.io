\begin_body

\begin_layout Title

\series bold
Self-consistent Majorana nanowire models
\end_layout

\begin_layout Author
Pablo San-Jose, Elsa Prada, Francisco Lobo
\end_layout

\begin_layout Section
Hartree-Fock-Nambu 
\begin_inset Newline linebreak
\end_inset

mean-field theory 
\end_layout

\begin_layout Standard
Consider a generic interacting Hamiltonian 
\begin_inset Formula $H=H_{0}+H_{\text{int}}$
\end_inset

 of the form
\begin_inset Formula 
\begin{align}
\hat{H} & =\sum_{\alpha\beta}h_{\alpha\beta}c_{\alpha}^{\dagger}c_{\beta}+\frac{1}{2}\sum_{\alpha\beta\gamma\delta}V_{\gamma\delta}^{\alpha\beta}c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}c_{\delta},
\end{align}

\end_inset

with 
\begin_inset Formula $c^{\dagger}(c)$
\end_inset

 fermionic creation (annihilation) operators and 
\begin_inset Formula $\alpha,\,\beta,\,\gamma,\,\delta$
\end_inset

 generic degrees of freedom.
 The time-dependency on 
\begin_inset Formula $h$
\end_inset

 and fermionic operators being omitted for clarity.
 Concerning the interaction term, we assume 
\begin_inset Formula $V(\mathbf{r})$
\end_inset

 to be a generic electrostatic (i.e spin independent) potential of symmetry
 
\begin_inset Formula $V(\mathbf{r}-\mathbf{r}^{\prime})=V(\mathbf{r}^{\prime}-\mathbf{r})$
\end_inset

 such that the interaction tensor elements have the symmetries 
\begin_inset Formula $V_{\gamma\delta}^{\alpha\beta}=V_{\delta\gamma}^{\beta\alpha}$
\end_inset

 and 
\begin_inset Formula $(V_{\gamma\delta}^{\alpha\beta})^{*}=V_{\alpha\beta}^{\gamma\delta}$
\end_inset

.
 
\end_layout

\begin_layout Standard
This system's purely electronic reduced density matrix (rDM) is defined
 as 
\begin_inset Formula $\rho_{ba}^{\text{ee}}=\langle c_{a}^{\dagger}c_{b}\rangle$
\end_inset

.
 However, if one wishes to study superconducting systems, one must also
 account for the anomalous rDM.
 For this, we introduce the Nambu spinor representation with doubling of
 degrees of freedom 
\begin_inset Formula $\check{c}_{a}=(c_{a}\,\,c_{a}^{\dagger})$
\end_inset

.
 The Nambu representation of the rDM, can then be written as the tensor
 product of this spinors for each of the spin combinations,
\begin_inset Formula 
\begin{equation}
\rho_{ab}=\left(\begin{array}{cc}
\langle c_{b}^{\dagger}c_{a}\rangle & \langle c_{b}c_{a}\rangle\\
\langle c_{b}^{\dagger}c_{a}^{\dagger}\rangle & \langle c_{b}c_{a}^{\dagger}\rangle
\end{array}\right)=\left(\begin{array}{cc}
\rho_{ab}^{\text{ee}} & \rho_{ab}^{\text{eh}}\\
\rho_{ab}^{\text{he}} & \rho_{ab}^{\text{hh}}
\end{array}\right).\label{eq:rho}
\end{equation}

\end_inset

These four contributions do, of course, relate to each other as 
\begin_inset Formula $\rho_{ab}^{\text{hh}}=-\rho_{ba}^{\text{ee}}+\delta_{ab}$
\end_inset

 and 
\begin_inset Formula $\rho_{ab}^{\text{he}}=(\rho_{ba}^{\text{eh}})^{*}$
\end_inset

, but also 
\begin_inset Formula $\rho_{ab}^{\text{ee/hh}}=(\rho_{ba}^{\text{ee/hh}})^{*}$
\end_inset

 and 
\begin_inset Formula $\rho_{ba}^{\text{eh/he}}=-\rho_{ab}^{\text{eh/he}}$
\end_inset

 directly from the (equal-time) fermionic anti-commutator properties.
\end_layout

\begin_layout Standard
Assume we wish to study the time-evolution of the Nambu rDM.
 This amounts to solving both the normal and anomalous rDM equation of motions
 with the fermionic operators evolving accordingly to the Heisenberg equation.
 Hence, one needs to evaluate the commutators 
\begin_inset Formula $[H,c_{b}^{\dagger}]$
\end_inset

 and 
\begin_inset Formula $[H,c_{a}]$
\end_inset

 which result in four-operator expectation values.
 To deal with such term we perform a mean-field decoupling where we approximate
 a two-particle expectation value to a product of two one-particle's.
 From Wick's theorem we have that, for example for the purely electronic
 rDM,
\begin_inset Formula 
\begin{equation}
\langle c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}c_{\delta}\rangle\approx\mathfrak{\rho}_{\beta\alpha}^{\text{he}}\mathfrak{\rho}_{\delta\gamma}^{\text{eh}}-\rho_{\gamma\alpha}^{\text{ee}}\rho_{\delta\beta}^{\text{ee}}+\rho_{\delta\alpha}^{\text{ee}}\rho_{\gamma\beta}^{\text{ee}}.\label{eq:mf}
\end{equation}

\end_inset

Defining Hartree, Fock and pairing self-energies (themselves dependent on
 the rDM) as
\begin_inset Formula 
\begin{equation}
\begin{array}{c}
\Sigma_{ab}^{H}=\sum_{\gamma\delta}V_{b\gamma}^{\delta a}\rho_{\gamma\delta}^{\text{ee}}\vspace{2mm}\\
\Sigma_{ab}^{F}=-\sum_{\gamma\delta}V_{b\gamma}^{a\delta}\rho_{\gamma\delta}^{\text{ee}}
\end{array}\quad\text{and}\quad\,\Delta_{ab}=\sum_{\gamma\delta}V_{\delta\gamma}^{ab}\rho_{\gamma\delta}^{\text{eh}}
\end{equation}

\end_inset

(note the symmetry 
\begin_inset Formula $\Delta_{ab}=-\Delta_{ba}$
\end_inset

) allows one to write the Nambu rDM EoM in terms of an effective Bogoliubov-de
 Gennes (BdG) Hamiltonian as simply as
\begin_inset Formula 
\begin{align*}
 & i\hbar\frac{d}{dt}\rho_{ab}=\left[H_{ab}^{\text{BdG}},\rho_{ab}\right]\text{ with }H_{ab}^{\text{BdG}}=\left(\begin{array}{cc}
h_{ab}^{\text{HF}} & \Delta_{ab}\\
\Delta_{ba}^{*} & -h_{ba}^{\text{HF}}
\end{array}\right)
\end{align*}

\end_inset

with the Hartree-Fock Hamiltonian being
\emph on

\begin_inset Formula 
\begin{equation}
h_{\text{HF}}(\rho)=h+\boldsymbol{\Sigma}_{H}(\rho)+\boldsymbol{\Sigma}_{F}(\rho).
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
Furthermore, consider now the approximation where the orbitals are ultra-localiz
ed (known as Wannier orbitals) such that 
\begin_inset Formula $V_{\gamma\delta}^{\alpha\beta}\approx V(\mathbf{r}_{\alpha}-\mathbf{r}_{\beta})\delta_{\alpha\delta}\delta_{\beta\gamma}$
\end_inset

.
 Within the scope of this approximation the interaction Hamiltonian will
 simply read as 
\begin_inset Formula $H_{\text{int}}=\frac{1}{2}\sum_{\alpha\beta}V^{\alpha\beta}c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\beta}c_{\alpha}$
\end_inset

 with 
\begin_inset Formula $V^{\alpha\beta}\equiv V(\mathbf{r}_{\alpha}-\mathbf{r}_{\beta})$
\end_inset

.
 
\begin_inset Note Comment
status collapsed

\begin_layout Plain Layout
The Hartree and Fock self-energies become 
\begin_inset Formula $\Sigma_{ab}^{H}=\sum_{\gamma}V^{a\gamma}\rho_{\gamma\gamma}^{\text{\text{ee}}}\delta_{ab}$
\end_inset

 and 
\begin_inset Formula $\Sigma_{ab}^{F}=-V^{ab}\rho_{ab}^{\text{ee}}$
\end_inset

, and the pairing 
\begin_inset Formula $\Delta_{ab}=V^{ab}\rho_{ab}^{\text{\text{eh}}}$
\end_inset

.
\end_layout

\end_inset

 Furthermore, for the sake of getting the problem in a tight-binding scheme,
 we isolate the degrees of freedom into purely spatial and spin indices
 
\begin_inset Formula $a\rightarrow i\sigma_{i}$
\end_inset

 such that
\begin_inset Formula 
\[
\boldsymbol{\rho}_{ij}=\left(\begin{array}{cc}
\boldsymbol{\rho}_{ij}^{\text{\text{ee}}} & \boldsymbol{\rho}_{ij}^{\text{eh}}\\
\boldsymbol{\rho}_{ji}^{\text{he}} & \boldsymbol{\rho}_{ji}^{\text{\text{hh}}}
\end{array}\right)=\left(\begin{array}{cc|cc}
\rho_{i\uparrow j\uparrow}^{\text{ee}} & \rho_{i\uparrow j\downarrow}^{\text{ee}} & \rho_{i\uparrow j\uparrow}^{\text{eh}} & \rho_{i\uparrow j\downarrow}^{\text{eh}}\\
\rho_{i\downarrow j\uparrow}^{\text{ee}} & \rho_{i\downarrow j\downarrow}^{\text{ee}} & \rho_{s\downarrow\uparrow}^{\text{eh}} & \rho_{i\downarrow j\downarrow}^{\text{eh}}\\
\hline \rho_{i\uparrow j\uparrow}^{\text{he}} & \rho_{i\uparrow j\downarrow}^{\text{he}} & \rho_{i\uparrow j\uparrow}^{\text{hh}} & \rho_{i\downarrow j\uparrow}^{\text{hh}}\\
\rho_{i\downarrow j\uparrow}^{\text{he}} & \rho_{i\downarrow j\downarrow}^{\text{he}} & \rho_{i\uparrow j\downarrow}^{\text{hh}} & \rho_{i\downarrow j\downarrow}^{\text{hh}}
\end{array}\right)
\]

\end_inset

Note the use of the bold to denote that an object possesses a spin structure.
 Moreover, notice that, since we considered the interaction to be spin-independe
nt, we also have that 
\begin_inset Formula $V^{i\sigma_{i}j\sigma_{j}}\equiv V^{ij}$
\end_inset

.
 In this basis, the self-energies read as 
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align}
\Sigma_{i\sigma_{i}j\sigma_{j}}^{H}= & \sum_{s}V^{is}\left(\rho_{s\uparrow s\uparrow}^{\text{\text{ee}}}+\rho_{s\downarrow s\downarrow}^{\text{\text{ee}}}\right)\delta_{ij}\delta_{\sigma_{i}\sigma_{j}}\\
\Sigma_{i\sigma_{i}j\sigma_{j}}^{F}= & -V^{ij}\rho_{i\sigma_{i}j\sigma_{j}}^{\text{ee}}\text{ and }\,\Delta_{i\sigma_{i}j\sigma_{j}}=V^{ij}\rho_{i\sigma_{i}j\sigma_{j}}^{\text{eh}}\nonumber 
\end{align}

\end_inset

Notice that the Hartree term is exclusively an onsite due to the 
\begin_inset Formula $\delta_{ij}$
\end_inset

.
 If we now define a new object related to the Nambu rDM but specifically
 having the same symmetries as the Nambu Hamiltonian, this being
\begin_inset Formula 
\begin{equation}
\tilde{\boldsymbol{\rho}}_{ij}=\left(\begin{array}{cc}
\boldsymbol{\rho}_{ij}^{\text{\text{ee}}} & -\boldsymbol{\rho}_{ij}^{\text{eh}}\\
-\left(\boldsymbol{\rho}_{ji}^{\text{eh}}\right)^{*} & -\boldsymbol{\rho}_{ji}^{\text{\text{ee}}}
\end{array}\right),
\end{equation}

\end_inset

we can then write the total self-energy of the system in an elegant and
 compact form as
\begin_inset Formula 
\[
\boldsymbol{\Sigma}_{ij}=\frac{1}{2}\sum_{s}V^{is}\text{Tr}\left(\left[\tau_{z}\otimes\sigma_{0}\right]\tilde{\boldsymbol{\rho}}_{ss}\right)\left[\tau_{z}\otimes\sigma_{0}\right]\delta_{ij}-V^{ij}\tilde{\boldsymbol{\rho}}_{ij},
\]

\end_inset

with both 
\begin_inset Formula $\sigma$
\end_inset

 and 
\begin_inset Formula $\tau$
\end_inset

 as Pauli matrices but operating in their respectively spin and electron-hole
 subspaces the Hamiltonian.
 
\end_layout

\begin_layout Standard
Moreover, in the limiting case of a spin-
\begin_inset Formula $1/2$
\end_inset

 Hubbard model one considers 
\begin_inset Formula $V^{ij}=U\delta_{ij}$
\end_inset

 such that mean field decoupling gives rise to just the onsite term,
\begin_inset Formula 
\begin{equation}
\boldsymbol{\Sigma}_{ij}=\frac{1}{2}U\left[\text{Tr}\left(\left[\tau_{z}\otimes\sigma_{0}\right]\tilde{\boldsymbol{\rho}}_{ii}\right)\left[\tau_{z}\otimes\sigma_{0}\right]-2\tilde{\boldsymbol{\rho}}_{ij}\right]\delta_{ij}.
\end{equation}

\end_inset


\end_layout

\begin_layout Section
Minimal Majorana model
\end_layout

\begin_layout Standard
First and foremost, prior to a self-consistence discussion, we showcase
 the foundation of Majorana physics through the study of the minimal model
 from which Majoranas emerge.
 Once this groundwork is laid, we hopefully look for similar results in
 our self-consistent model.
 The minimal model consists of a finite one-dimensional 
\begin_inset Formula $s$
\end_inset

-type superconductive (SC) nanowire of static pairing 
\begin_inset Formula $\Delta_{0}$
\end_inset

 in the presence of an external Zeeman field 
\begin_inset Formula $V_{\text{Z}}$
\end_inset

 whilst accounting for spin-orbit coupling (SOC), being described by the
 Hamiltonian,
\begin_inset Formula 
\begin{align}
\hat{\boldsymbol{H}} & =\sum_{\sigma_{i}\sigma_{j}}c_{\sigma_{i}}^{\dagger}\left(-\eta\partial_{x}^{2}-\mu+\alpha_{\text{R}}i\sigma_{y}\partial_{x}+V_{\text{Z}}\sigma_{z}\right)c_{\sigma_{j}}\nonumber \\
 & +\frac{1}{2}(\Delta_{0}c_{\uparrow}^{\dagger}c_{\downarrow}^{\dagger}+\Delta_{0}c_{\downarrow}c_{\uparrow}).
\end{align}

\end_inset


\end_layout

\begin_layout Standard
with 
\begin_inset Formula $\eta=\hbar^{2}/2m^{*}$
\end_inset

 and 
\begin_inset Formula $m^{*}$
\end_inset

 the electron effective mass and 
\begin_inset Formula $\mu$
\end_inset

 the chemical potential.
 The SOC being due an externally applied transverse magnetic field of Rashba
 strength 
\begin_inset Formula $\alpha_{\text{R}}$
\end_inset

 and the Zeeman splitting 
\begin_inset Formula $V_{\text{Z}}=g_{J}\mu_{B}B_{x}/2$
\end_inset

 due to a in-plane magnetic field 
\begin_inset Formula $B_{x}$
\end_inset

, with 
\begin_inset Formula $g_{J}$
\end_inset

 the Landé 
\emph on
g
\emph default
yromagnetic factor of the semiconductor and 
\begin_inset Formula $\mu_{B}$
\end_inset

 Bohr's magneton.
 
\end_layout

\begin_layout Standard
Furthermore, within the Nambu tight-binding scheme presented in the previous
 section, having defined the spinor 
\begin_inset Formula $\boldsymbol{\check{c}}_{i}=(c_{i\uparrow}\,\,c_{i\downarrow}\,\,c_{i\uparrow}^{\dagger}\,\,c_{i\downarrow}^{\dagger})$
\end_inset

, the corresponding Hamiltonian matrix reads as
\begin_inset Formula 
\begin{align}
\boldsymbol{H} & =\left(f\delta_{ij}-t\delta_{ij\pm1}\right)\left[\tau_{z}\otimes\sigma_{0}\right]+\Delta_{0}\left[\tau_{y}\otimes\sigma_{y}\right]\delta_{ij}\nonumber \\
 & +\frac{\alpha_{\text{R}}}{2a_{0}}\delta_{ij\pm1}^{\pm}\left[\tau_{z}\otimes i\sigma_{y}\right]+V_{\text{Z}}\left[\tau_{z}\otimes\sigma_{z}\right]\delta_{ij}\label{eq:H}
\end{align}

\end_inset

with 
\begin_inset Formula $f=2t-\mu$
\end_inset

 the band filling (
\begin_inset Formula $\mu=0$
\end_inset

 and 
\begin_inset Formula $\mu=2t$
\end_inset

 corresponding to half and zero filling respectively), 
\begin_inset Formula $t=\eta/a_{0}^{2}$
\end_inset

 the hopping parameter.
 The Kronecker delta terms 
\begin_inset Formula $\delta_{ij}$
\end_inset

 and 
\begin_inset Formula $\delta_{ij\pm1}^{\pm}$
\end_inset

 denote the on-site terms and the 1st neighbors hoppings, front and back.
 
\begin_inset Note Comment
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\[
\hat{\boldsymbol{H}}_{0}=\boldsymbol{\hat{c}}^{\dagger}\left[\begin{array}{ccc|ccc||ccc|ccc}
f+V_{\text{Z}} & -t &  & 0 & \frac{\alpha_{\text{R}}}{2a_{0}} &  &  &  &  & -\Delta_{0}\\
-t & \ddots & \ddots & \frac{\alpha_{\text{R}}}{2a_{0}} & \ddots & \ddots &  &  &  &  & \ddots\\
 & \ddots & \ddots &  & \ddots & \ddots &  &  &  &  &  & \ddots\\
\hline 0 & -\frac{\alpha_{\text{R}}}{2a_{0}} &  & f-V_{\text{Z}} & -t &  & \Delta_{0} &  & \\
-\frac{\alpha_{\text{R}}}{2a_{0}} & \ddots & \ddots & -t & \ddots & \ddots &  & \ddots & \\
 & \ddots &  &  & \ddots &  &  &  & \ddots\\
\hline\hline  &  &  & \Delta_{0} &  &  & -f-V_{\text{Z}} & t &  & 0 & -\frac{\alpha_{\text{R}}}{2a_{0}}\\
 &  &  &  & \ddots &  & t & \ddots & \ddots & -\frac{\alpha_{\text{R}}}{2a_{0}} & \ddots & \ddots\\
 &  &  &  &  & \ddots &  & \ddots &  &  & \ddots\\
\hline -\Delta_{0} &  &  &  &  &  & 0 & \frac{\alpha_{\text{R}}}{2a_{0}} &  & -f+V_{\text{Z}} & t\\
 & \ddots &  &  &  &  & \frac{\alpha_{\text{R}}}{2a_{0}} & \ddots & \ddots & t & \ddots & \ddots\\
 &  & \ddots &  &  &  &  & \ddots &  &  & \ddots
\end{array}\right]\left[\begin{array}{c}
c_{1\uparrow}\\
c_{2\uparrow}\\
c_{3\uparrow}\\
\vdots\\
\hline c_{1\downarrow}\\
c_{2\downarrow}\\
c_{3\downarrow}\\
\vdots\\
\hline\hline c_{1\uparrow}^{\dagger}\\
c_{2\uparrow}^{\dagger}\\
c_{3\uparrow}^{\dagger}\\
\vdots\\
\hline c_{1\downarrow}^{\dagger}\\
c_{2\downarrow}^{\dagger}\\
c_{3\downarrow}^{\dagger}\\
\vdots
\end{array}\right]
\]

\end_inset


\end_layout

\end_inset


\end_layout

