\begin_layout Standard
Consider a Majorana 1D nanowire along the 
\begin_inset Formula $\hat{\mathbf{z}}$
\end_inset

 direction as described in Fig.(
\begin_inset Formula $\text{\ref{fig:HFwire}}$
\end_inset

)(a).
 
\begin_inset Float figure
wide false
sideways false
status open

\begin_layout Plain Layout
\align center
\begin_inset Graphics
	filename images/ring.svg
	scale 50

\end_inset


\end_layout

\begin_layout Plain Layout
\begin_inset Caption Standard

\begin_layout Plain Layout
Model 
\begin_inset CommandInset label
LatexCommand label
name "fig:ring"

\end_inset


\end_layout

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Standard
Consider now that the edges 
\begin_inset Formula $i=1,N$
\end_inset

 of the nanowire connect to one another as a weak link, forming a ring in
 the plane 
\begin_inset Formula $x\mathcal{O}y$
\end_inset

, as shown in Fig.(
\begin_inset Formula $\text{\ref{fig:RMW}}$
\end_inset

)(c).
 We then apply a magnetic field 
\begin_inset Formula $B_{z}$
\end_inset

 through the middle of the ring such that the kinetic term of the Hamiltonian
 is modified as 
\begin_inset Formula $\left(-i\hbar\boldsymbol{\nabla}+e\mathbf{A}\right)^{2}/2m_{0}$
\end_inset

, with 
\begin_inset Formula $-e$
\end_inset

 the electron's charge and 
\begin_inset Formula $\mathbf{A}$
\end_inset

 the magnetic vector potential.
 The vector potential is constrained by the magnetic flux 
\begin_inset Formula $\Phi$
\end_inset

 through the ring as 
\begin_inset Formula $\oint d\mathbf{r}\cdot\mathbf{A}(\mathbf{r})=\Phi$
\end_inset

.
 According to Peierl's substitutions, assuming that the vector potential
 changes slowly and is approximately uniform at the Wannier lattice scale,
 the modified hopping 
\begin_inset Formula $\tilde{t}$
\end_inset

 in quasi-equilibrium stays the same apart from the phase factor picked
 up, reading as
\begin_inset Formula 
\[
\tilde{t}_{ij}=t_{ij}e^{-i\frac{e}{\hbar}\phi_{ij}},\text{ with }\phi_{ij}=e^{-i\frac{e}{\hbar}\int_{\mathbf{r}_{i}}^{\mathbf{r}_{j}}d\mathbf{r}^{\prime}\cdot\mathbf{A}(\mathbf{r}^{\prime})}
\]

\end_inset

Furthermore, one can then chose a gauge 
\begin_inset Formula $\mathbf{A}(\mathbf{r})\rightarrow\mathbf{A}(\mathbf{r}^{\prime})+\boldsymbol{\nabla}\boldsymbol{\Lambda}(\mathbf{r})$
\end_inset

 where the vector potential vanishes everywhere except in the weak link,
 so 
\begin_inset Formula $\phi_{ij}=\phi\delta_{i1}\delta_{jN}$
\end_inset

.
 The weak link hopping phase reads as 
\begin_inset Formula $\phi=n\Phi/\Phi_{0}$
\end_inset

 with 
\begin_inset Formula $\Phi_{0}=h/2e$
\end_inset

 the fluxoid (superconducting flux quanta) with 
\begin_inset Formula $2e$
\end_inset

 the charge of the Cooper pair and 
\begin_inset Formula $\Phi=\pi R^{2}B_{z}$
\end_inset

 with 
\begin_inset Formula $R$
\end_inset

 the ring radius.
 
\begin_inset Note Comment
status collapsed

\begin_layout Plain Layout
The modified hopping can be computed directly from
\begin_inset Formula 
\[
\tilde{t}_{\mathbf{R}\mathbf{R}^{\prime}}=-\int d\mathbf{r}\tilde{\phi}_{\mathbf{R}}^{*}(\mathbf{r})\hat{\tilde{K}}\tilde{\phi}_{\mathbf{R}^{\prime}}(\mathbf{r})
\]

\end_inset

where 
\begin_inset Formula $\hat{\tilde{K}}$
\end_inset

 is the modified kinetic operator and 
\begin_inset Formula $\phi$
\end_inset

 are the modified Wannier functions
\begin_inset Formula 
\[
\tilde{\Psi}(\mathbf{r})=\frac{1}{\sqrt{N}}\sum_{\mathbf{R}}e^{i\mathbf{k}\cdot\mathbf{R}}\tilde{\phi}_{\mathbf{R}}(\mathbf{r}),\quad\text{with }\tilde{\phi}_{\mathbf{R}}(\mathbf{r})=e^{-i\frac{e}{\hbar}\int_{\mathbf{R}}^{\mathbf{r}}\mathbf{A}(\mathbf{r}^{\prime})d\mathbf{r}^{\prime}}\phi_{\mathbf{R}}(\mathbf{r}).
\]

\end_inset

Having that
\begin_inset Formula 
\begin{align*}
2m_{0}\hat{\tilde{K}}\tilde{\phi}_{\mathbf{R}^{\prime}}(\mathbf{r})= & \left(-i\hbar\boldsymbol{\nabla}_{\mathbf{r}}+e\mathbf{A}\right)^{2}e^{-i\frac{e}{\hbar}\int_{\mathbf{R^{\prime}}}^{\mathbf{r}}\mathbf{A}(\mathbf{r}^{\prime})d\mathbf{r}^{\prime}}\phi_{\mathbf{R^{\prime}}}(\mathbf{r})\\
= & \left[\left(\hbar^{2}\nabla_{r}^{2}-2ie\hbar\boldsymbol{\nabla}_{\mathbf{r}}\cdot\mathbf{A}+e^{2}A^{2}\right)e^{-i\frac{e}{\hbar}\int_{\mathbf{R^{\prime}}}^{\mathbf{r}}\mathbf{A}(\mathbf{r}^{\prime})d\mathbf{r}^{\prime}}\right]\phi_{\mathbf{R^{\prime}}}(\mathbf{r})\\
 & +e^{-i\frac{e}{\hbar}\int_{\mathbf{R^{\prime}}}^{\mathbf{r}}\mathbf{A}(\mathbf{r}^{\prime})d\mathbf{r}^{\prime}}\left[\left(\hbar^{2}\nabla_{r}^{2}-2ie\hbar\boldsymbol{\nabla}_{\mathbf{r}}\cdot\mathbf{A}+e^{2}A^{2}\right)\phi_{\mathbf{R^{\prime}}}(\mathbf{r})\right]\\
= & ...\\
= & e^{-i\frac{e}{\hbar}\int_{\mathbf{R^{\prime}}}^{\mathbf{r}}\mathbf{A}(\mathbf{r}^{\prime})d\mathbf{r}^{\prime}}\left(\mathbf{p}+e\mathbf{A}-e\mathbf{A}\right)^{2}\phi_{\mathbf{R^{\prime}}}(\mathbf{r})\\
= & e^{-i\frac{e}{\hbar}\int_{\mathbf{R^{\prime}}}^{\mathbf{r}}\mathbf{A}(\mathbf{r}^{\prime})d\mathbf{r}^{\prime}}\hat{K}\phi_{\mathbf{R^{\prime}}}(\mathbf{r})
\end{align*}

\end_inset

the modified hopping interval gives
\begin_inset Formula 
\begin{align*}
\tilde{t}_{\mathbf{R}\mathbf{R}^{\prime}} & =-\int d\mathbf{r}\left(e^{+i\frac{e}{\hbar}\int_{\mathbf{R}}^{\mathbf{r}}\mathbf{A}(\mathbf{r}^{\prime})d\mathbf{r}^{\prime}}\phi_{\mathbf{R}}^{*}(\mathbf{r})\right)\left(e^{-i\frac{e}{\hbar}\int_{\mathbf{R^{\prime}}}^{\mathbf{r}}\mathbf{A}(\mathbf{r}^{\prime})d\mathbf{r}^{\prime}}\hat{K}\phi_{\mathbf{R^{\prime}}}(\mathbf{r})\right)\\
 & =-e^{-i\frac{e}{\hbar}\int_{\mathbf{R}}^{\mathbf{R^{\prime}}}\mathbf{A}(\mathbf{r}^{\prime})d\mathbf{r}^{\prime}}\int d\mathbf{r}\phi_{\mathbf{R}}^{*}(\mathbf{r})e^{-i\frac{e}{\hbar}\Phi_{\mathbf{R}^{\prime},\mathbf{r},\mathbf{R}}}\hat{K}\phi_{\mathbf{R^{\prime}}}(\mathbf{r})
\end{align*}

\end_inset

where we have defined
\begin_inset Formula 
\[
\Phi_{\mathbf{R}^{\prime},\mathbf{r},\mathbf{R}}=\oint_{\mathbf{R}^{\prime}\rightarrow\mathbf{r}\rightarrow\mathbf{R}\rightarrow\mathbf{R}^{\prime}}\mathbf{A}(\mathbf{r}^{\prime})d\mathbf{r}^{\prime}
\]

\end_inset

the flux through the triangle made by the three position arguments.
 Now, since we assume 
\begin_inset Formula $\mathbf{A}(\mathbf{r})$
\end_inset

 approximately uniform at the Wannier lattice scale we can approximate it
 to zero yielding the desired result
\begin_inset Formula $_{\square}$
\end_inset

.
\end_layout

\begin_layout Plain Layout
Concerning the gauge choice such that rotational symmetry is broken and
 the weak-link's direction is preferred.
\end_layout

\end_inset


\end_layout

\begin_layout Standard
According to the Meissner effect, the screening currents flowing in the
 London's penetration depth 
\begin_inset Formula $\lambda_{\text{L}}$
\end_inset

 outer shell create a magnetization which perfectly compensates the applied
 field, thus resulting in 
\begin_inset Formula $\mathbf{B}=0$
\end_inset

 within the bulk of the superconductor.
 However, note that the value of the flux quantum is equal to 
\begin_inset Formula $\Phi_{0}$
\end_inset

 is only true if the path around the hole lays in the bulk, several 
\begin_inset Formula $\lambda_{\text{L}}$
\end_inset

 away from the surface.
 Since we are considering a 1D nanowire this condition is then not satisfied.
 
\end_layout

