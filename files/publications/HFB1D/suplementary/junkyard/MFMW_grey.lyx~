\end_layout

\begin_layout Plain Layout
First we calculate the commutator with 
\begin_inset Formula $c_{b}^{\dagger}$
\end_inset

 making use of the following commutator properties.
 We obtain
\begin_inset Formula 
\begin{align*}
\left[c_{\alpha}^{\dagger}c_{\beta},c_{b}^{\dagger}\right] & =c_{\alpha}^{\dagger}\left\{ c_{\beta},c_{b}^{\dagger}\right\} -\cancel{\left\{ c_{b}^{\dagger},c_{\alpha}^{\dagger}\right\} }c_{\beta}=c_{\alpha}^{\dagger}\delta_{\beta b}\\
\left[c_{\beta}c_{\alpha}^{\dagger},c_{b}^{\dagger}\right] & =c_{\beta}\cancel{\left\{ c_{\alpha}^{\dagger},c_{b}^{\dagger}\right\} }-\left\{ c_{b}^{\dagger},c_{\beta}\right\} c_{\alpha}^{\dagger}=-c_{\alpha}^{\dagger}\delta_{\beta b}
\end{align*}

\end_inset

and that
\begin_inset Formula 
\begin{align*}
\left[c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}c_{\delta},c_{b}^{\dagger}\right] & =c_{\alpha}^{\dagger}c_{\beta}^{\dagger}\left(c_{\gamma}\left\{ c_{\delta},c_{b}^{\dagger}\right\} -\left\{ c_{b}^{\dagger},c_{\gamma}\right\} c_{\delta}\right)+\left(c_{\alpha}^{\dagger}\cancel{\left\{ c_{\beta}^{\dagger},c_{b}^{\dagger}\right\} }-\cancel{\left\{ c_{b}^{\dagger},c_{\alpha}^{\dagger}\right\} }c_{\beta}^{\dagger}\right)c_{\gamma}c_{\delta}=c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}\delta_{\delta b}-c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\delta}\delta_{\gamma b}\\
\left[c_{\delta}c_{\gamma}c_{\beta}^{\dagger}c_{\alpha}^{\dagger},c_{b}^{\dagger}\right] & =c_{\delta}c_{\gamma}\left(c_{\beta}^{\dagger}\cancel{\left\{ c_{\alpha}^{\dagger},c_{b}^{\dagger}\right\} }-\cancel{\left\{ c_{b}^{\dagger},c_{\beta}^{\dagger}\right\} }c_{\alpha}^{\dagger}\right)+\left(c_{\delta}\left\{ c_{\gamma},c_{b}^{\dagger}\right\} -\left\{ c_{b}^{\dagger},c_{\delta}\right\} c_{\gamma}\right)c_{\beta}^{\dagger}c_{\alpha}^{\dagger}=c_{\delta}c_{\beta}^{\dagger}c_{\alpha}^{\dagger}\delta_{\gamma b}-c_{\gamma}c_{\beta}^{\dagger}c_{\alpha}^{\dagger}\delta_{\delta b}
\end{align*}

\end_inset

The complete commutator then reads
\begin_inset Formula 
\begin{align*}
[H,c_{b}^{\dagger}] & =\left[\frac{1}{2}\bar{h}_{\alpha\beta}\left(c_{\alpha}^{\dagger}c_{\beta}-c_{\beta}c_{\alpha}^{\dagger}\right)+\frac{1}{4}V_{\gamma\delta}^{\alpha\beta}\left(c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}c_{\delta}+c_{\delta}c_{\gamma}c_{\beta}^{\dagger}c_{\alpha}^{\dagger}\right)+\frac{1}{2}\cancel{\tilde{h}_{0}},c_{b}^{\dagger}\right]\\
 & =\frac{1}{2}\bar{h}_{\alpha\beta}\left(\left[c_{\alpha}^{\dagger}c_{\beta},c_{b}^{\dagger}\right]-\left[c_{\beta}c_{\alpha}^{\dagger},c_{b}^{\dagger}\right]\right)+\frac{1}{4}V_{\gamma\delta}^{\alpha\beta}\left(\left[c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}c_{\delta},c_{b}^{\dagger}\right]+\left[c_{\delta}c_{\gamma}c_{\beta}^{\dagger}c_{\alpha}^{\dagger},c_{b}^{\dagger}\right]\right)\\
 & =\bar{h}_{\alpha\beta}c_{\alpha}^{\dagger}\delta_{\beta b}+\frac{1}{4}\left(V_{\gamma\delta}^{\alpha\beta}c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}\delta_{\delta b}-V_{\gamma\delta}^{\alpha\beta}c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\delta}\delta_{\gamma b}+V_{\gamma\delta}^{\alpha\beta}c_{\delta}c_{\beta}^{\dagger}c_{\alpha}^{\dagger}\delta_{\gamma b}-V_{\gamma\delta}^{\alpha\beta}c_{\gamma}c_{\beta}^{\dagger}c_{\alpha}^{\dagger}\delta_{\delta b}\right)\\
 & =\bar{h}_{\alpha b}c_{\alpha}^{\dagger}+\frac{1}{4}\left(V_{\gamma b}^{\alpha\beta}-V_{b\gamma}^{\alpha\beta}\right)\left(c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}-c_{\gamma}c_{\beta}^{\dagger}c_{\alpha}^{\dagger}\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Plain Layout
Analogous for the 
\begin_inset Formula $[H,c_{a}]$
\end_inset

 commutator, we have
\begin_inset Formula 
\begin{align*}
\left[c_{\alpha}^{\dagger}c_{\beta},c_{a}\right] & =c_{\alpha}^{\dagger}\cancel{\left\{ c_{\beta},c_{a}\right\} }-\left\{ c_{a},c_{\alpha}^{\dagger}\right\} c_{\beta}=-c_{\beta}\delta_{a\alpha}\\
\left[c_{\beta}c_{\alpha}^{\dagger},c_{a}\right] & =c_{\beta}\left\{ c_{\alpha}^{\dagger},c_{a}\right\} -\cancel{\left\{ c_{a},c_{\beta}\right\} }c_{\alpha}^{\dagger}=c_{\beta}\delta_{a\alpha}
\end{align*}

\end_inset

and that
\begin_inset Formula 
\begin{align*}
\left[c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}c_{\delta},c_{a}\right] & =c_{\alpha}^{\dagger}c_{\beta}^{\dagger}\left(c_{\gamma}\cancel{\left\{ c_{\delta},c_{a}\right\} }-\cancel{\left\{ c_{a},c_{\gamma}\right\} }c_{\delta}\right)+\left(c_{\alpha}^{\dagger}\left\{ c_{\beta}^{\dagger},c_{a}\right\} -\left\{ c_{a},c_{\alpha}^{\dagger}\right\} c_{\beta}^{\dagger}\right)c_{\gamma}c_{\delta}=c_{\alpha}^{\dagger}c_{\gamma}c_{\delta}\delta_{\beta a}-c_{\beta}^{\dagger}c_{\gamma}c_{\delta}\delta_{a\alpha}\\
\left[c_{\delta}c_{\gamma}c_{\beta}^{\dagger}c_{\alpha}^{\dagger},c_{a}\right] & =c_{\delta}c_{\gamma}\left(c_{\beta}^{\dagger}\left\{ c_{\alpha}^{\dagger},c_{a}\right\} -\left\{ c_{a},c_{\beta}^{\dagger}\right\} c_{\alpha}^{\dagger}\right)+\left(c_{\delta}\cancel{\left\{ c_{\gamma},c_{a}\right\} }-\cancel{\left\{ c_{a},c_{\delta}\right\} }c_{\gamma}\right)c_{\beta}^{\dagger}c_{\alpha}^{\dagger}=c_{\delta}c_{\gamma}c_{\beta}^{\dagger}\delta_{\alpha a}-c_{\delta}c_{\gamma}c_{\alpha}^{\dagger}\delta_{a\beta}
\end{align*}

\end_inset

The complete commutator then reads
\begin_inset Formula 
\begin{align*}
[H,c_{a}] & =\left[\frac{1}{2}\bar{h}_{\alpha\beta}\left(c_{\alpha}^{\dagger}c_{\beta}-c_{\beta}c_{\alpha}^{\dagger}\right)+\frac{1}{4}V_{\gamma\delta}^{\alpha\beta}\left(c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}c_{\delta}+c_{\delta}c_{\gamma}c_{\beta}^{\dagger}c_{\alpha}^{\dagger}\right)+\frac{1}{2}\cancel{\tilde{h}_{0}},c_{a}\right]\\
 & =\frac{1}{2}\bar{h}_{\alpha\beta}\left(\left[c_{\alpha}^{\dagger}c_{\beta},c_{a}\right]-\left[c_{\beta}c_{\alpha}^{\dagger},c_{a}\right]\right)+\frac{1}{4}V_{\gamma\delta}^{\alpha\beta}\left(\left[c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\gamma}c_{\delta},c_{a}\right]+\left[c_{\delta}c_{\gamma}c_{\beta}^{\dagger}c_{\alpha}^{\dagger},c_{a}\right]\right)\\
 & =-\bar{h}_{\alpha\beta}c_{\beta}\delta_{a\alpha}+\frac{1}{4}\left(V_{\gamma\delta}^{\alpha\beta}c_{\alpha}^{\dagger}c_{\gamma}c_{\delta}\delta_{\beta a}-V_{\gamma\delta}^{\alpha\beta}c_{\beta}^{\dagger}c_{\gamma}c_{\delta}\delta_{a\alpha}+V_{\gamma\delta}^{\alpha\beta}c_{\delta}c_{\gamma}c_{\beta}^{\dagger}\delta_{\alpha a}-V_{\gamma\delta}^{\alpha\beta}c_{\delta}c_{\gamma}c_{\alpha}^{\dagger}\delta_{a\beta}\right)\\
 & =-\bar{h}_{a\beta}c_{\beta}+\frac{1}{4}\left(V_{\gamma\delta}^{\alpha a}c_{\alpha}^{\dagger}c_{\gamma}c_{\delta}-V_{\gamma\delta}^{a\beta}c_{\beta}^{\dagger}c_{\gamma}c_{\delta}+V_{\gamma\delta}^{a\beta}c_{\delta}c_{\gamma}c_{\beta}^{\dagger}-V_{\gamma\delta}^{\alpha a}c_{\delta}c_{\gamma}c_{\alpha}^{\dagger}\right)\\
 & =-\bar{h}_{a\alpha}c_{\alpha}+\frac{1}{4}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\left(c_{\alpha}^{\dagger}c_{\beta}c_{\gamma}-c_{\gamma}c_{\beta}c_{\alpha}^{\dagger}\right)
\end{align*}

\end_inset


