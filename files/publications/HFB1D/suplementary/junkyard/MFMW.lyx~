Normal rDM EoM calculations
\end_layout

\begin_layout Plain Layout
For the non-interacting terms we simply have that
\begin_inset Formula 
\begin{align*}
\rho_{a\alpha}^{\text{ee}}\bar{h}_{\alpha b}-\bar{h}_{a\alpha}\rho_{\alpha b}^{\text{ee}} & =\boldsymbol{\rho}_{\text{ee}}\bar{\boldsymbol{h}}-\bar{\boldsymbol{h}}\boldsymbol{\rho}_{\text{ee}}=-\left[\bar{\boldsymbol{h}},\boldsymbol{\rho}_{\text{ee}}\right]
\end{align*}

\end_inset


\end_layout

\begin_layout Plain Layout
For the interaction terms we perform a mean-field decoupling on the 4-operator
 terms, reading
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
 & \frac{1}{2}\left(V_{\gamma b}^{\alpha\beta}-V_{b\gamma}^{\alpha\beta}\right)\left(\mathfrak{\rho}_{\beta\alpha}^{\text{he}}\mathfrak{\rho}_{a\gamma}^{\text{eh}}-\rho_{\gamma\alpha}^{\text{ee}}\rho_{a\beta}^{\text{ee}}+\rho_{a\alpha}^{\text{ee}}\rho_{\gamma\beta}^{\text{ee}}\right)+\frac{1}{2}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\left(\mathfrak{\rho}_{\alpha b}^{\text{he}}\mathfrak{\rho}_{\gamma\beta}^{\text{eh}}-\rho_{\beta b}^{\text{ee}}\rho_{\gamma\alpha}^{\text{ee}}+\rho_{\gamma b}^{\text{ee}}\rho_{\beta\alpha}^{\text{ee}}\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Plain Layout
The purely electronic terms read as
\begin_inset Formula 
\begin{align*}
 & \frac{1}{2}\rho_{a\beta}^{\text{ee}}\left(-\left(V_{\gamma b}^{\alpha\beta}-V_{b\gamma}^{\alpha\beta}\right)+\left(V_{\gamma b}^{\beta\alpha}-V_{b\gamma}^{\beta\alpha}\right)\right)\rho_{\gamma\alpha}^{\text{ee}}+\frac{1}{2}\left(-\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)+\left(V_{\gamma\beta}^{\alpha a}-V_{\gamma\beta}^{a\alpha}\right)\right)\rho_{\gamma\alpha}^{\text{ee}}\rho_{\beta b}^{\text{ee}}\\
= & \rho_{a\beta}^{\text{ee}}\left(\Sigma^{\text{HF}}\right)_{\beta b}^{\text{ee}}-\left(\Sigma^{\text{HF}}\right)_{a\beta}^{\text{ee}}\rho_{\beta b}^{\text{ee}}=-\left[\boldsymbol{\Sigma}_{\text{ee}}^{\text{HF}},\boldsymbol{\rho}_{\text{ee}}\right]
\end{align*}

\end_inset

and the anomalous terms as
\begin_inset Formula 
\begin{align*}
 & \frac{1}{2}\mathfrak{\rho}_{a\gamma}^{\text{eh}}\left(V_{\gamma b}^{\alpha\beta}-V_{b\gamma}^{\alpha\beta}\right)\mathfrak{\rho}_{\beta\alpha}^{\text{he}}+\frac{1}{2}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\mathfrak{\rho}_{\gamma\beta}^{\text{eh}}\mathfrak{\rho}_{\alpha b}^{\text{he}}\\
= & \frac{1}{2}\mathfrak{\rho}_{a\gamma}^{\text{eh}}\left[\left(V_{\beta\alpha}^{b\gamma}-V_{\beta\alpha}^{\gamma b}\right)\mathfrak{\rho}_{\alpha\beta}^{\text{eh}}\right]^{\dagger}+\frac{1}{2}\left(\Delta_{\alpha a}^{\text{eh}}-\Delta_{a\alpha}^{\text{eh}}\right)\mathfrak{\rho}_{\alpha b}^{\text{he}}\\
= & \frac{1}{2}\mathfrak{\rho}_{a\gamma}^{\text{eh}}\left(\Delta_{b\gamma}^{\text{eh}}-\Delta_{\gamma b}^{\text{eh}}\right)^{\dagger}+\frac{1}{2}\left(\Delta_{\alpha a}^{\text{eh}}-\Delta_{a\alpha}^{\text{eh}}\right)\mathfrak{\rho}_{\alpha b}^{\text{he}}=\boldsymbol{\rho}_{\text{eh}}\boldsymbol{\Delta}_{\text{eh}}^{*}-\boldsymbol{\Delta}_{\text{eh}}\boldsymbol{\mathfrak{\rho}}_{\text{he}}
\end{align*}

\end_inset


\end_layout

\end_inset

With the normal EoM expressed, we now focus on the anomalous EoM,
\begin_inset Formula 
\begin{equation}
\frac{d}{dt}\rho_{ab}^{\text{eh}}=\left\langle \frac{i}{\hbar}[\mathcal{H},\psi_{b}]\psi_{a}\right\rangle +\left\langle \psi_{b}\frac{i}{\hbar}[\mathcal{H},\psi_{a}]\right\rangle .\label{eq:EoMan}
\end{equation}

\end_inset

where, and using the result shown in Eq.(
\begin_inset Formula $\text{\ref{eq:Hca}}$
\end_inset

), we need to perform the addition mean-field decoupling
\begin_inset Formula 
\begin{align*}
\left\langle \psi_{\alpha}^{\dagger}\psi_{\beta}\psi_{\gamma}\psi_{a}\right\rangle  & \approx\rho_{\beta\alpha}^{\text{ee}}\rho_{a\gamma}^{\text{eh}}-\rho_{\gamma\alpha}^{\text{ee}}\rho_{a\beta}^{\text{eh}}+\rho_{a\alpha}^{\text{ee}}\rho_{\gamma\beta}^{\text{eh}}\\
\left\langle \psi_{b}\psi_{\alpha}^{\dagger}\psi_{\beta}\psi_{\gamma}\right\rangle  & \approx\rho_{\alpha b}^{\text{hh}}\rho_{\gamma\beta}^{\text{eh}}-\rho_{\beta b}^{\text{eh}}\rho_{\gamma\alpha}^{\text{ee}}+\rho_{\gamma b}^{\text{eh}}\rho_{\beta\alpha}^{\text{ee}}
\end{align*}

\end_inset

This yields the anomalous equation of motion
\begin_inset Formula 
\begin{equation}
i\hbar\frac{d}{dt}\boldsymbol{\rho}_{\text{eh}}=\mathbf{H}_{\text{HF}}\boldsymbol{\rho}_{\text{eh}}+\boldsymbol{\rho}_{\text{eh}}\mathbf{H}_{\text{HF}}^{T}-\boldsymbol{\rho}_{\text{ee}}\boldsymbol{\Delta}_{\text{eh}}+\boldsymbol{\Delta}_{\text{eh}}\boldsymbol{\rho}_{\text{hh}}\label{eq:EoM_an}
\end{equation}

\end_inset


