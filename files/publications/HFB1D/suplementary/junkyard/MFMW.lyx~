\begin_layout Subsection
Wannier limit
\end_layout

\begin_layout Standard
We make the simplification of considering our orbitals to be ultra-localized,
 as known as 
\emph on
Wannier
\emph default
 orbitals.
 Within this approximation the interaction Hamiltonian simply reads as 
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
H_{\text{e-e}}\overset{\text{W}}{\approx}\frac{1}{2}\sum_{\alpha\beta}V^{\alpha\beta}c_{\alpha}^{\dagger}c_{\beta}^{\dagger}c_{\beta}c_{\alpha}\label{eq:Hint_2p}
\end{equation}

\end_inset

since, the interaction terms will become
\begin_inset Formula 
\begin{align}
V_{\gamma\delta}^{\alpha\beta} & \overset{\text{W}}{\approx}V(\mathbf{r}-\mathbf{r}^{\prime})\left(\int d\mathbf{r}\phi_{\alpha}^{*}(\mathbf{r})\phi_{\delta}(\mathbf{r})\right)\left(\int d\mathbf{r}^{\prime}\phi_{\beta}^{*}(\mathbf{r}^{\prime})\phi_{\gamma}(\mathbf{r}^{\prime})\right)=V^{\alpha\beta}\delta_{\alpha\delta}\delta_{\beta\gamma}
\end{align}

\end_inset

due to the orthogonal properties of some arbitrary electronic basis 
\begin_inset Formula $\left\{ \phi_{\alpha}(\mathbf{r})\right\} $
\end_inset

.
 For convenience we wrote 
\begin_inset Formula $V(\mathbf{r}_{\alpha}-\mathbf{r}_{\beta})=V^{\alpha\beta}$
\end_inset

.
 Within the scope of this approximation (and dropping the 
\begin_inset Formula $\overset{\text{W}}{\approx}$
\end_inset

 notation) the Hartree, Fock and pairing self-energies become
\begin_inset Formula 
\begin{equation}
\left(\Sigma^{H}\right)_{ab}^{\text{ee}}=\sum_{\gamma}V^{a\gamma}\rho_{\gamma\gamma}^{\text{\text{ee}}}\delta_{ab}\quad\text{and}\quad\left(\Sigma^{F}\right)_{ab}^{\text{\text{ee}}}=-V^{ab}\rho_{ab}^{\text{ee}},\quad\text{and}\quad\Delta_{ab}^{\text{eh}}=V^{ab}\rho_{ab}^{\text{\text{eh}}}
\end{equation}

\end_inset

Next, for the sake of getting it in a tight-binding implementable form,
 we specify the generic degrees of freedom indices as a site index and make
 explicit the spin degree of freedom 
\begin_inset Formula $\sigma_{s}=\uparrow/\downarrow$
\end_inset

 (so, for example, 
\begin_inset Formula $\gamma\rightarrow s\sigma_{s}$
\end_inset

).
 Moreover, since we considered the interaction to be spin-independent, we
 have that 
\begin_inset Formula $V^{i\sigma_{i}j\sigma_{j}}\equiv V^{ij}$
\end_inset

.
 In this basis, the self-energies read as
\begin_inset Formula 
\begin{equation}
\left(\Sigma^{H}\right)_{i\sigma_{i}j\sigma_{j}}^{\text{ee}}=\sum_{s}V^{is}\left(\rho_{s\uparrow s\uparrow}^{\text{\text{ee}}}+\rho_{s\downarrow s\downarrow}^{\text{\text{ee}}}\right)\delta_{ij}\delta_{\sigma_{i}\sigma_{j}}\quad\text{and}\quad\left(\Sigma^{F}\right)_{i\sigma_{i}j\sigma_{j}}^{\text{\text{ee}}}=-V^{ij}\rho_{i\sigma_{i}j\sigma_{j}}^{\text{ee}},\quad\text{and}\quad\Delta_{i\sigma_{i}j\sigma_{j}}^{\text{eh}}=V^{ij}\rho_{i\sigma_{i}j\sigma_{j}}^{\text{eh}}
\end{equation}

\end_inset

Notice that the Hartree terms are exclusively an onsite due to the 
\begin_inset Formula $\delta_{ij}$
\end_inset

 (and thus, from now on, we relax the onsite notation 
\begin_inset Formula $i\sigma_{i}i\sigma_{j}\equiv i\sigma_{i}\sigma_{j}$
\end_inset

).
 Because of this we must introduce manually corrections to the Hartree term
 since both the Fock and pairing terms also have onsite terms when 
\begin_inset Formula $i=j$
\end_inset

.
 Therefore, we implicitly take this term out of the Fock and pairing term
 and put it in in the Hartree.
 We now define a new rDM object specifically to have the same symmetries
 as the Nambu Hamiltonian,
\begin_inset Formula 
\begin{equation}
\tilde{\boldsymbol{\rho}}_{ij}=\left(\begin{array}{cc}
\boldsymbol{\rho}_{ij}^{\text{\text{ee}}} & -\boldsymbol{\rho}_{ij}^{\text{eh}}\\
-\boldsymbol{\rho}_{ji}^{\text{eh}} & -\sigma_{y}\boldsymbol{\rho}_{ji}^{\text{ee}}\sigma_{y}
\end{array}\right),\quad\text{opposed to}\quad\boldsymbol{\rho}_{ij}=\left(\begin{array}{cc}
\boldsymbol{\rho}_{ij}^{\text{ee}} & \boldsymbol{\rho}_{ij}^{\text{eh}}\\
\left(\boldsymbol{\rho}_{ji}^{\text{eh}}\right)^{\dagger} & -\boldsymbol{\rho}_{ji}^{\text{ee}}+\delta_{ij}\delta_{\sigma_{i}\sigma_{j}}
\end{array}\right)
\end{equation}

\end_inset

which allows us to write the total self-energy of the system in an elegant
 and compact form as
\begin_inset Formula 
\begin{equation}
\boldsymbol{\Sigma}_{ij}=\frac{1}{2}\sum_{s}V^{is}\text{Tr}\left(\tau_{z}\bar{\boldsymbol{\rho}}_{s}\right)\left[\tau_{z}\otimes\sigma_{0}\right]\delta_{ij}-V^{ij}\tilde{\boldsymbol{\rho}}_{ij}
\end{equation}

\end_inset


