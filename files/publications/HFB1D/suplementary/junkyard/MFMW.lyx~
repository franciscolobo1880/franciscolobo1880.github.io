\mathcal{H}_{\text{eq}} & =h+\mathcal{H}_{\text{int}}=\sum_{\alpha\beta}h_{\alpha\beta}\psi_{\alpha}^{\dagger}\psi_{\beta}+\frac{1}{2}\sum_{\alpha\beta\gamma\delta}V_{\gamma\delta}^{\alpha\beta}\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}\psi_{\gamma}\psi_{\delta},\label{eq:H2quantum}
\end{align}

\end_inset

with 
\begin_inset Formula $\psi^{\dagger}(\psi)$
\end_inset

 fermionic creation (annihilation) operators and 
\begin_inset Formula $\alpha,\,\beta,\,\gamma,\,\delta$
\end_inset

 representing generic degrees of freedom, as usual up until now.
 Concerning the interaction term, we assume 
\begin_inset Formula $V(\mathbf{r})$
\end_inset

 to be generic electrostatic (i.e spin independent) potential of symmetry
 
\begin_inset Formula $V(\mathbf{r}-\mathbf{r}^{\prime})=V(\mathbf{r}^{\prime}-\mathbf{r})$
\end_inset

 such that the interaction tensor elements have the symmetries
\begin_inset Formula 
\begin{equation}
V_{\gamma\delta}^{\alpha\beta}=V_{\delta\gamma}^{\beta\alpha}\quad\text{and}\quad\left(V_{\gamma\delta}^{\alpha\beta}\right)^{*}=V_{\alpha\beta}^{\gamma\delta}.\label{eq:Vsym}
\end{equation}

\end_inset

Consider now that we perturb our system with an externally applied time-dependen
t force 
\begin_inset Formula $F(t)$
\end_inset

, such that system is instead described by the Hamiltonian
\begin_inset Formula 
\begin{equation}
\mathcal{H}(t)=\mathcal{H}_{\text{eq}}+\mathcal{H}_{\text{per}}(t)=\sum_{\alpha\beta}\left(h_{\alpha\beta}+B_{\alpha\beta}F(t)\right)\psi_{\alpha}^{\dagger}\psi_{\beta}+\frac{1}{2}\sum_{\alpha\beta\gamma\delta}V_{\gamma\delta}^{\alpha\beta}\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}\psi_{\gamma}\psi_{\delta}.
\end{equation}

\end_inset

where 
\begin_inset Formula $B_{\alpha\beta}$
\end_inset

 are matrix elements of a one-particle operator that couples to the external
 force.
 For convenience, we define 
\begin_inset Formula $\bar{h}_{\alpha\beta}\equiv h_{\alpha\beta}+B_{\alpha\beta}F(t)$
\end_inset

.
\end_layout

\begin_layout Standard
In order to study the dynamics of this system, we focus the system's time-depend
ent reduced density matrix (rDM) which is defined as
\begin_inset Formula 
\begin{equation}
\rho_{ba}^{\text{ee}}(t)=\left\langle \psi_{a}^{\dagger}(t)\psi_{b}(t)\right\rangle \label{eq:rhodef}
\end{equation}

\end_inset

for the purely electronic interaction case (hence the 
\begin_inset Formula $ee$
\end_inset

).
 However, since we are looking for superconducting solutions, we wish to
 account also for the anomalous terms 
\begin_inset Formula $\langle\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}\rangle$
\end_inset

 and 
\begin_inset Formula $\langle\psi_{\gamma}\psi_{a}\rangle$
\end_inset

 and thus we introduce once again the Nambu spinor representation 
\begin_inset Formula $\Psi_{\alpha}(t)=\left(\begin{array}{c}
\begin{array}{c}
\psi_{\alpha}(t)\end{array}\\
\psi_{\alpha}^{\dagger}(t)
\end{array}\right)$
\end_inset

.
 The Nambu representation of the rDM, can then be written as the tensor
 product of this spinors for each of the spin combinations,
\begin_inset Formula 
\begin{equation}
\boldsymbol{\rho}_{ab}(t)=\left\langle \Psi_{b}^{\dagger}\otimes\Psi_{a}\right\rangle =\left(\begin{array}{cc}
\left\langle \psi_{b}^{\dagger}\psi_{a}\right\rangle  & \left\langle \psi_{b}\psi_{a}\right\rangle \\
\left\langle \psi{}_{b}^{\dagger}\psi_{a}^{\dagger}\right\rangle  & \left\langle \psi_{b}\psi_{a}^{\dagger}\right\rangle 
\end{array}\right)=\left(\begin{array}{cc}
\rho_{ab}^{\text{ee}} & \rho_{ab}^{\text{eh}}\\
\rho_{ab}^{\text{he}} & \rho_{ab}^{\text{hh}}
\end{array}\right)\label{eq:rDM_def}
\end{equation}

\end_inset

where we have omitted (and will continue to omit most of the time) the time-depe
ndency in both the rDM and fermionic operators for clarity.
 This terms are related as
\begin_inset Formula 
\begin{equation}
\rho_{ab}^{\text{hh}}=-\rho_{ba}^{\text{ee}}+\delta_{ab}\quad\text{and}\quad\rho_{ab}^{\text{ee/hh}}=\left(\rho_{ba}^{\text{ee/hh}}\right)^{\dagger},\quad\text{and}\quad\rho_{ab}^{\text{he}}=\left(\rho_{ba}^{\text{eh}}\right)^{\dagger}\quad\text{and}\quad\rho_{ba}^{\text{eh/he}}=-\rho_{ab}^{\text{eh/he}}\label{eq:rho_rel}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
Our task now is then to solve the four (actually two) equation of motions
 for each of the terms in Eq.(
\begin_inset Formula $\text{\ref{eq:rDM_def}}$
\end_inset

).
\end_layout

\begin_layout Subsection
Reduced density matrix equation of motion
\end_layout

\begin_layout Standard
We start by solving for the normal rDM equation of motions
\begin_inset Formula 
\begin{equation}
\frac{d}{dt}\rho_{ab}^{\text{ee}}(t)=\left\langle \frac{d\psi_{b}^{\dagger}(t)}{dt}\psi_{a}(t)\right\rangle +\left\langle \psi_{b}^{\dagger}(t)\frac{d\psi_{a}(t)}{dt}\right\rangle ,
\end{equation}

\end_inset

in the Heisenberg picture of quantum mechanics, where the fermionic operators
 evolve accordingly to the Heisenberg equation.
 Therefore the rDM equation of motion reads
\begin_inset Formula 
\begin{equation}
\frac{d}{dt}\rho_{ab}^{\text{ee}}=\left\langle \frac{i}{\hbar}[\mathcal{H},\psi_{b}^{\dagger}]\psi_{a}\right\rangle +\left\langle \psi_{b}^{\dagger}\frac{i}{\hbar}[\mathcal{H},\psi_{a}]\right\rangle .\label{eq:EM_rho}
\end{equation}

\end_inset

where we have omitted the time dependency in the fermionic operators for
 compactness.
 This practice is done throughout the remaining work with no further mention.
 As shown in Appendix, given the equal-time fermionic anti-commutator properties
 
\begin_inset Formula $\left\{ \psi_{a},\psi_{b}^{\dagger}\right\} =\left\{ \psi_{b}^{\dagger},\psi_{a}\right\} =\delta_{ab}$
\end_inset

 and 
\begin_inset Formula $\left\{ \psi_{a},\psi_{b}\right\} =\left\{ \psi_{b}^{\dagger},\psi_{a}^{\dagger}\right\} =0$
\end_inset

, each of the commutators are evaluated to
\begin_inset Formula 
\begin{align*}
[\mathcal{H},\psi_{b}^{\dagger}] & =\bar{h}_{\alpha b}\psi_{\alpha}^{\dagger}+\frac{1}{2}\left(V_{\gamma b}^{\alpha\beta}-V_{b\gamma}^{\alpha\beta}\right)\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}\psi_{\gamma}\\{}
[\mathcal{H},\psi_{a}] & =-\bar{h}_{a\alpha}\psi_{\alpha}+\frac{1}{2}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\psi_{\alpha}^{\dagger}\psi_{\beta}\psi_{\gamma},
\end{align*}

\end_inset

where we have hidden the summations on repeated indices using Einstein's
 notation.
 Substituting Eqs.(
\begin_inset Formula $\text{\ref{eq:Hcb}}$
\end_inset

) and (
\begin_inset Formula $\text{\ref{eq:Hca}}$
\end_inset

) back into Eq.(
\begin_inset Formula $\text{\ref{eq:EM_rho}}$
\end_inset

) yields
\begin_inset Formula 
\begin{align*}
-i\hbar\frac{d}{dt}\rho_{ab}^{\text{ee}} & =\left(\rho_{a\alpha}^{\text{ee}}\bar{h}_{\alpha b}-\bar{h}_{a\alpha}\rho_{\alpha b}^{\text{ee}}\right)+\frac{1}{2}\left(V_{\gamma b}^{\alpha\beta}-V_{b\gamma}^{\alpha\beta}\right)\left\langle \psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}\psi_{\gamma}\psi_{a}\right\rangle +\frac{1}{2}\left(V_{\beta\gamma}^{\alpha a}-V_{\beta\gamma}^{a\alpha}\right)\left\langle \psi_{b}^{\dagger}\psi_{\alpha}^{\dagger}\psi_{\beta}\psi_{\gamma}\right\rangle 
\end{align*}

\end_inset

where we came back to the definition of the normal rDM in Eq.(
\begin_inset Formula $\text{\ref{eq:rhodef}}$
\end_inset

) for the first two terms.
 Notice, however, that the remaining interaction terms correspond to the
 expectation values of four-operators.
 For this, we introduce a mean-field approximation where we assume the two-parti
cle expectation value to simply behave as a product of two one-particle
 expectation values.
 From this mean-field decoupling we can then make use of 
\emph on
Wick's theorem
\emph default
 as done in the Appendix.
 We obtain
\begin_inset Formula 
\begin{align}
\left\langle \psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}\psi_{\gamma}\psi_{\delta}\right\rangle  & \approx\mathfrak{\rho}_{\beta\alpha}^{\text{he}}\mathfrak{\rho}_{\delta\gamma}^{\text{eh}}-\rho_{\gamma\alpha}^{\text{ee}}\rho_{\delta\beta}^{\text{ee}}+\rho_{\delta\alpha}^{\text{ee}}\rho_{\gamma\beta}^{\text{ee}}
\end{align}

\end_inset

Through this mean-field decoupling we obtain a rDM equation of motion reading
 as
\begin_inset Formula 
\begin{align}
i\hbar\frac{d}{dt}\boldsymbol{\rho}_{\text{ee}}= & \left[\mathbf{H}_{\text{HF}},\boldsymbol{\rho}_{\text{ee}}\right]-\boldsymbol{\rho}_{\text{eh}}\boldsymbol{\Delta}_{\text{eh}}^{*}+\boldsymbol{\Delta}_{\text{eh}}\boldsymbol{\mathfrak{\rho}}_{\text{he}}
\end{align}

\end_inset

where we defined the Hartree and Fock normal self energies and the pairing
 self-energy, themselves dependent on the rDM, as
\begin_inset Formula 
\begin{equation}
\left(\Sigma^{H}\right)_{ab}^{\text{ee}}=V_{b\gamma}^{\delta a}\rho_{\gamma\delta}^{\text{ee}}\quad\text{and}\quad\left(\Sigma^{F}\right)_{ab}^{\text{ee}}=-V_{b\gamma}^{a\delta}\rho_{\gamma\delta}^{\text{ee}},\quad\text{and}\quad\Delta_{ab}^{\text{eh}}\equiv V_{\delta\gamma}^{ab}\rho_{\gamma\delta}^{\text{eh}}
\end{equation}

\end_inset

such that the Hartree-Fock Hamiltonian reads as
\emph on

\begin_inset Formula 
\begin{equation}
\mathbf{H}_{\text{HF}}[\boldsymbol{\rho}(t)]=\boldsymbol{h}+\boldsymbol{B}F(t)+\boldsymbol{\Sigma}_{\text{ee}}^{H}[\boldsymbol{\rho}(t)]+\boldsymbol{\Sigma}_{\text{ee}}^{F}[\boldsymbol{\rho}(t)]\equiv\bar{\boldsymbol{h}}+\boldsymbol{\Sigma}_{\text{ee}}^{\text{HF}}
\end{equation}

\end_inset


\emph default
Note the symmetry 
\begin_inset Formula $\Delta_{ab}=-\Delta_{ba}$
\end_inset

.
