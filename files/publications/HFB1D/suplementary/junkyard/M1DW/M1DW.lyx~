\sigma_{i}\left[\begin{array}{c}
\psi_{\tilde{\alpha}\uparrow}\\
\psi_{\tilde{\alpha}\downarrow}
\end{array}\right]\\
\sigma_{i}\left[\begin{array}{c}
\psi_{\tilde{\alpha}\downarrow}^{*}\\
-\psi_{\tilde{\alpha}\uparrow}^{*}
\end{array}\right]
\end{array}\right)\quad\text{and}\quad\tau_{i}\Psi_{\alpha}\rightarrow\left(\tau_{i}\otimes\sigma_{0}\right)\Psi_{\alpha}=\tau_{i}\left(\begin{array}{c}
\psi_{\alpha}\\
\psi_{\alpha}^{\dagger}
\end{array}\right)
\]

