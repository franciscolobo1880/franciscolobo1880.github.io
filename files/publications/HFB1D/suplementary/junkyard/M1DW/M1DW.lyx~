\begin_inset Formula 
\begin{align*}
\psi_{\alpha}^{\dagger}\psi_{\beta} & =\frac{1}{2}\psi_{\alpha}^{\dagger}\psi_{\beta}+\frac{1}{2}\psi_{\alpha}^{\dagger}\psi_{\beta}=\frac{1}{2}\psi_{\alpha}^{\dagger}\psi_{\beta}-\frac{1}{2}\psi_{\beta}\psi_{\alpha}^{\dagger}=\frac{1}{2}\left(\psi_{\alpha}^{\dagger}\,\psi_{\alpha}\right)\left(\begin{array}{cc}
