\begin_inset Formula 
\begin{equation}
\mathcal{H}_{\text{SC}}=\frac{1}{2}\Delta(x)\psi_{\tilde{\alpha}\uparrow}^{*}(x)\psi_{\tilde{\alpha}\downarrow}^{*}(x)+c.c
\end{equation}

\end_inset


