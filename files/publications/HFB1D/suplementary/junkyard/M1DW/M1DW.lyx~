\begin_inset Formula $t_{\alpha,\beta}^{\text{NN}}=t_{0}\langle\tilde{\tilde{\alpha}}|\mathcal{H}_{\text{R}}|\tilde{\tilde{\beta}}\delta_{\sigma\sigma^{\prime}}\rangle$
\end_inset

.
