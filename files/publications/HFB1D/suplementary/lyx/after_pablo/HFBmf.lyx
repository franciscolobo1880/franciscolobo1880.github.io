\begin_layout Standard
\begin_inset Formula 
\begin{align}
\frac{d}{dt}\rho_{eh}^{\boldsymbol{i}\boldsymbol{j}}= & \frac{i}{\hbar}\left\langle [H,c_{\boldsymbol{j}}]c_{\boldsymbol{i}}\right\rangle +\frac{i}{\hbar}\left\langle c_{\boldsymbol{j}}[H,c_{\boldsymbol{i}}]\right\rangle \\
\left\langle [H,c_{\boldsymbol{j}}]c_{\boldsymbol{i}}\right\rangle = & -\sum_{\boldsymbol{\alpha}}H_{0}^{\boldsymbol{j}\boldsymbol{\alpha}}\rho_{eh}^{\boldsymbol{i}\boldsymbol{\alpha}}-\sum_{\boldsymbol{\alpha}}v^{\alpha j}\left\langle c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\alpha}}c_{\boldsymbol{j}}c_{\boldsymbol{i}}\right\rangle \\
\left\langle c_{\boldsymbol{j}}[H,c_{\boldsymbol{i}}]\right\rangle = & -\sum_{\boldsymbol{\alpha}}H_{0}^{\boldsymbol{i}\boldsymbol{\alpha}}\rho_{eh}^{\boldsymbol{\alpha}\boldsymbol{j}}-\sum_{\boldsymbol{\alpha}}v^{\alpha i}\left\langle c_{\boldsymbol{j}}c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\alpha}}c_{\boldsymbol{i}}\right\rangle \\
\left\langle c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\alpha}}c_{\boldsymbol{j}}c_{\boldsymbol{i}}\right\rangle \approx & \rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{\alpha}}\rho_{eh}^{\boldsymbol{i}\boldsymbol{j}}-\rho_{ee}^{\boldsymbol{j}\boldsymbol{\alpha}}\rho_{eh}^{\boldsymbol{i}\boldsymbol{\alpha}}+\rho_{ee}^{\boldsymbol{i}\boldsymbol{\alpha}}\rho_{eh}^{\boldsymbol{j}\boldsymbol{\alpha}}\\
\left\langle c_{\boldsymbol{j}}c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\alpha}}c_{\boldsymbol{i}}\right\rangle \approx & \rho_{hh}^{\boldsymbol{\alpha}\boldsymbol{j}}\rho_{eh}^{\boldsymbol{i}\boldsymbol{\alpha}}-\rho_{eh}^{\boldsymbol{\alpha}\boldsymbol{j}}\rho_{ee}^{\boldsymbol{i}\boldsymbol{\alpha}}+\rho_{eh}^{\boldsymbol{i}\boldsymbol{j}}\rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{\alpha}}
\end{align}

\end_inset

and finally
\begin_inset Formula 
\begin{align}
i\hbar\frac{d}{dt}\boldsymbol{\rho}_{eh}^{\boldsymbol{i}\boldsymbol{j}}\approx & \boldsymbol{H}_{HF}^{ij}\cdot\boldsymbol{\rho}_{eh}^{ij}+\boldsymbol{\rho}_{eh}^{ij}\cdot\left(\boldsymbol{H}_{HF}^{ij}\right)^{T}\nonumber \\
 & +\boldsymbol{\Sigma}_{B}^{ij}\cdot\boldsymbol{\rho}_{hh}^{ij}-\boldsymbol{\rho}_{ee}^{ij}\cdot\boldsymbol{\Sigma}_{B}^{ij}
\end{align}

\end_inset


