\end_layout

\end_inset


\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{equation}
V_{\boldsymbol{j}^{\prime}\boldsymbol{i}^{\prime}}^{\boldsymbol{i}\boldsymbol{j}}\approx v^{\boldsymbol{i}\boldsymbol{j}}\delta_{\boldsymbol{i}\boldsymbol{i}^{\prime}}\delta_{\boldsymbol{j}\boldsymbol{j}^{\prime}}\label{eq:V}
\end{equation}

\end_inset


\end_layout

\end_inset


\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
hspace{-0.35cm}
\end_layout

\end_inset

mediated by a spinless electrostatic scalar potential 
\begin_inset Flex Color Box
status open

\begin_layout Plain Layout
\begin_inset Argument 1
status open

\begin_layout Plain Layout
colback=yellow!10!white, colframe=yellow!10!white, breakable
\end_layout

\end_inset


\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
vspace{-0.35cm}
\end_layout

\end_inset


\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{equation}
v^{\boldsymbol{i}\boldsymbol{j}}\rightarrow v^{ij}=v(\vec{r}_{i}-\vec{r}_{j}),\,\text{with }v^{ij}=v^{ji}.\label{eq:v}
\end{equation}

\end_inset


\end_layout

\end_inset

It follows that
\begin_inset Formula 
\begin{align}
H_{\text{int}} & =\frac{1}{2}\sum_{\boldsymbol{i}\boldsymbol{j}}\sum_{\boldsymbol{i}^{\prime}\boldsymbol{j}^{\prime}}c_{\boldsymbol{i}}^{\dagger}c_{\boldsymbol{i}^{\prime}}\left(v^{\boldsymbol{i}\boldsymbol{j}}\delta_{\boldsymbol{i}\boldsymbol{i}^{\prime}}\delta_{\boldsymbol{j}\boldsymbol{j}^{\prime}}\right)c_{\boldsymbol{j}}^{\dagger}c_{\boldsymbol{j}^{\prime}}\nonumber \\
 & =\frac{1}{2}\sum_{\boldsymbol{i}\boldsymbol{j}}c_{\boldsymbol{i}}^{\dagger}c_{\boldsymbol{i}}v^{ij}c_{\boldsymbol{j}}^{\dagger}c_{\boldsymbol{j}}\label{eq:Hint}
\end{align}

\end_inset


\end_layout

\begin_layout Standard
A perturbation theory treatment of the interaction based on path integrals
 starts by casting the Hamiltonian into its normal-ordered form.
 Given the equal-time fermionic anti-commutator properties,
\begin_inset Formula 
\begin{align}
 & \{c_{i},c_{j}^{\dagger}\}=c_{i}c_{j}^{\dagger}+c_{j}^{\dagger}c_{i}\label{eq:anticom1}\\
 & \{c_{i},c_{j}^{\dagger}\}=\{c_{j}^{\dagger},c_{i}\}=\delta_{ij}\label{eq:anticom2}\\
 & \{c_{i},c_{j}\}=\{c_{j}^{\dagger},c_{i}^{\dagger}\}=0,\label{eq:anticom3}
\end{align}

\end_inset

one obtains
\begin_inset Formula 
\begin{align}
H_{\text{int}}= & \frac{1}{2}\sum_{\boldsymbol{i}\boldsymbol{j}}c_{\boldsymbol{i}}^{\dagger}c_{\boldsymbol{i}}v^{ij}c_{\boldsymbol{j}}^{\dagger}c_{\boldsymbol{j}}\nonumber \\
= & \frac{1}{2}\sum_{\boldsymbol{i}\boldsymbol{j}}c_{\boldsymbol{i}}^{\dagger}\left(\delta_{\boldsymbol{i}\boldsymbol{j}}-c_{\boldsymbol{j}}^{\dagger}c_{\boldsymbol{i}}\right)c_{\boldsymbol{j}}v^{ij}\nonumber \\
= & \frac{1}{2}c_{\boldsymbol{i}}^{\dagger}c_{\boldsymbol{i}}v^{ii}-\frac{1}{2}\sum_{\boldsymbol{i}\boldsymbol{j}}c_{\boldsymbol{i}}^{\dagger}c_{\boldsymbol{j}}^{\dagger}v^{ij}c_{\boldsymbol{i}}c_{\boldsymbol{j}}\label{eq:spurious}
\end{align}

\end_inset

See that from the normal ordering of 
\begin_inset Formula $H_{\text{int}}$
\end_inset

 a non-physical spurious self-interaction term 
\begin_inset Formula $1/2c_{\boldsymbol{i}}^{\dagger}c_{\boldsymbol{i}}v^{ii}$
\end_inset

 reveals itself explicitly, which should not take part since single electrons
 cannot interact with themselves.
 This term can be removed preemptively by incorporating it in Eq.(
\begin_inset Formula $\text{\ref{eq:H}}$
\end_inset

) instead with a negative sign,
\begin_inset Formula 
\begin{equation}
H_{\text{int}}-=\frac{1}{2}\sum_{\boldsymbol{i}}c_{\boldsymbol{i}}^{\dagger}c_{\boldsymbol{i}}v^{ii}
\end{equation}

\end_inset

Within the scope of this approximation the normal-ordered Hamiltonians takes
 the form
\begin_inset Newline newline
\end_inset


\begin_inset Formula 
\begin{equation}
H=\sum_{\boldsymbol{i}\boldsymbol{j}}c_{\boldsymbol{i}}^{\dagger}H_{0}^{\boldsymbol{i}\boldsymbol{j}}c_{\boldsymbol{j}}+\frac{1}{2}\sum_{\boldsymbol{i}\boldsymbol{j}}c_{\boldsymbol{i}}^{\dagger}c_{\boldsymbol{j}}^{\dagger}v^{ij}c_{\boldsymbol{j}}c_{\boldsymbol{i}}\label{eq:H-1}
\end{equation}

\end_inset


\end_layout

\begin_layout Section
Mean-field Hartree-Fock-Bogoliubov decoupling
\end_layout

\begin_layout Standard
We wish to derive from Eq.(
\begin_inset Formula $\text{\ref{eq:H-1}}$
\end_inset

) the explicit form of the Hartree/electrostatic 
\begin_inset Formula $\Sigma_{H}$
\end_inset

, Fock/exchange 
\begin_inset Formula $\Sigma_{F}$
\end_inset

 and Bogoliubov/pairing 
\begin_inset Formula $\Sigma_{B}$
\end_inset

 self-energies between spatial sites 
\begin_inset Formula $i$
\end_inset

 and 
\begin_inset Formula $j$
\end_inset

, being matrices over orbital space.
 For this, one must Hartree-Fock-Bogoliubov decouple the Hamiltonian in
 Eq.(
\begin_inset Formula $\text{\ref{eq:H-1}}$
\end_inset

) such that it could be expressed as:
\begin_inset Formula 
\begin{align}
H & \approx H_{0}+H_{\text{int}}^{H}+H_{\text{int}}^{F}+H_{\text{int}}^{B}\\
 & =\sum_{\boldsymbol{i}\boldsymbol{j}}\left[c_{\boldsymbol{i}}^{\dagger}\left(H_{0}^{\boldsymbol{i}\boldsymbol{j}}+\Sigma_{H}^{\boldsymbol{i}\boldsymbol{j}}+\Sigma_{F}^{\boldsymbol{i}\boldsymbol{j}}\right)c_{\boldsymbol{j}}+\frac{1}{2}\left(c_{\boldsymbol{i}}^{\dagger}\Sigma_{B}^{\boldsymbol{i}\boldsymbol{j}}c_{\boldsymbol{j}}^{\dagger}+h.c\right)\right].\nonumber 
\end{align}

\end_inset

In particular, within a Nambu-spinor representation, which we will be presenting
 next, we should be able to make this Hamiltonian the form
\begin_inset Formula 
\begin{equation}
\check{H}=\frac{1}{2}\sum_{\boldsymbol{i}\boldsymbol{j}}\check{c}_{\boldsymbol{i}}\left(\check{H}_{0}^{\boldsymbol{i}\boldsymbol{j}}+\check{\Sigma}^{\boldsymbol{i}\boldsymbol{j}}\right)\check{c}_{\boldsymbol{j}},
\end{equation}

\end_inset

having an inherent Bogoliubov-de-Gennes (BdG) symmetry.
\end_layout

\begin_layout Subsection
Nambu representation
\end_layout

\begin_layout Standard
For this derivation we focus on the system's reduced density matrix (rDM)
 equation of motion (EoM).
 In normal systems, i.e non-superconducting systems, the rDM defined as 
\begin_inset Formula $\rho_{ee}=\langle c_{j}^{\dagger}c_{i}\rangle$
\end_inset

 is sufficient, however, if one wishes to study superconducting systems,
 one must also account for the anomalous/pairing terms.
 For this, we introduce Nambu-spinors representation with doubling of degrees
 of freedom so that electron 
\begin_inset Formula $e$
\end_inset

, hole 
\begin_inset Formula $h$
\end_inset

 become additional quantum numbers, 
\begin_inset Formula 
\begin{equation}
\check{c}_{i}^{\dagger}=\left(\begin{array}{cc}
c_{i}^{\dagger} & c_{i}\end{array}\right)\text{ and }\check{c}_{i}=\left(\begin{array}{c}
c_{i}\\
c_{i}^{\dagger}
\end{array}\right)
\end{equation}

\end_inset

The corresponding Nambu rDM, can then be written as the direct/tensor product
 of this Nambu-spinors for each of the 
\begin_inset Formula $e$
\end_inset

, 
\begin_inset Formula $h$
\end_inset

 combinations
\begin_inset Formula 
\begin{align}
\check{\rho}_{ij} & =\langle\check{c}_{j}^{\dagger}\otimes\check{c}_{i}\rangle\\
 & =\left(\begin{array}{cc}
\langle c_{j}^{\dagger}c_{i}\rangle & \langle c_{j}c_{i}\rangle\\
\langle c_{j}^{\dagger}c_{i}^{\dagger}\rangle & \langle c_{j}c_{i}^{\dagger}\rangle
\end{array}\right)\equiv\left(\begin{array}{cc}
\rho_{ee}^{ij} & \rho_{eh}^{ij}\\
\rho_{he}^{ij} & \rho_{hh}^{ij}
\end{array}\right)\nonumber 
\end{align}

\end_inset


\end_layout

\begin_layout Standard
Directly from the equal-time fermionic anti-commutator properties in Eqs.(
\begin_inset Formula $\text{\ref{eq:anticom1}}$
\end_inset

)-(
\begin_inset Formula $\text{\ref{eq:anticom3}}$
\end_inset

), this terms relate to themselves and to each other as
\begin_inset Formula 
\begin{align}
 & \rho_{ee}^{ij}=\left(\rho_{ee}^{ji}\right)^{\dagger}\text{ and }\rho_{eh}^{ij}=-\rho_{eh}^{ji}\label{eq:rrs}\\
 & \rho_{hh}^{ij}=\delta_{ij}-\rho_{ee}^{ji}\text{ and }\rho_{he}^{ij}=\left(\rho_{eh}^{ji}\right)^{\dagger}\label{eq:rrs-1}
\end{align}

\end_inset

Moreover, accounting for the additional spin orbital quantum number, the
 Nambu-spinor corresponds instead to the 4-spinor
