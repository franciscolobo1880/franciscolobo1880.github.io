\left\langle c_{\boldsymbol{j}}^{\dagger}c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\alpha}}c_{\boldsymbol{i}}\right\rangle  & \approx\mathfrak{\rho}_{he}^{\boldsymbol{\alpha}\boldsymbol{j}}\mathfrak{\rho}_{eh}^{\boldsymbol{i}\boldsymbol{\alpha}}-\rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{j}}\rho_{ee}^{\boldsymbol{i}\boldsymbol{\alpha}}+\rho_{ee}^{\boldsymbol{i}\boldsymbol{j}}\rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{\alpha}}
\end{align}

\end_inset


