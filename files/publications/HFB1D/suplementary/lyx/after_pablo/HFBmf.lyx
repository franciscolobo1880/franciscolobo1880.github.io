\begin_inset Formula 
\begin{align}
H & =H_{0}+H_{\text{int}}\nonumber \\
 & =\sum_{\boldsymbol{i}\boldsymbol{j}}c_{\boldsymbol{i}}^{\dagger}H_{0}^{\boldsymbol{i}\boldsymbol{j}}c_{\boldsymbol{j}}+\frac{1}{2}\sum_{\boldsymbol{i}\boldsymbol{j}}\sum_{\boldsymbol{i}^{\prime}\boldsymbol{j}^{\prime}}c_{\boldsymbol{i}}^{\dagger}c_{\boldsymbol{i}^{\prime}}V_{\boldsymbol{j}^{\prime}\boldsymbol{i}^{\prime}}^{\boldsymbol{i}\boldsymbol{j}}c_{\boldsymbol{j}}^{\dagger}c_{\boldsymbol{j}^{\prime}}\label{eq:H}
\end{align}

