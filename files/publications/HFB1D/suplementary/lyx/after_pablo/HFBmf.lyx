\end_layout

\end_inset


\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align}
\boldsymbol{\check{\rho}}_{ij} & =\langle\boldsymbol{\check{c}}_{j}^{\dagger}\otimes\boldsymbol{\check{c}}_{i}\rangle=\left(\begin{array}{cc}
\langle\boldsymbol{c}_{j}^{\dagger}\otimes\boldsymbol{c}_{i}\rangle & \langle\boldsymbol{c}_{j}\otimes\boldsymbol{c}_{i}\rangle\\
\langle\boldsymbol{c}_{j}^{\dagger}\otimes\boldsymbol{c}_{i}^{\dagger}\rangle & \langle\boldsymbol{c}_{j}\otimes\boldsymbol{c}_{i}^{\dagger}\rangle
\end{array}\right)\\
 & \equiv\left(\begin{array}{cc}
\boldsymbol{\rho}_{ee}^{ij} & \boldsymbol{\rho}_{eh}^{ij}\\
\boldsymbol{\rho}_{he}^{ij} & \boldsymbol{\rho}_{hh}^{ij}
\end{array}\right)\equiv\left(\begin{array}{cc|cc}
\rho_{ee}^{i\uparrow j\uparrow} & \rho_{ee}^{i\uparrow j\downarrow} & \rho_{eh}^{i\uparrow j\uparrow} & \rho_{eh}^{i\uparrow j\downarrow}\\
\rho_{ee}^{i\downarrow j\uparrow} & \rho_{ee}^{i\downarrow j\downarrow} & \rho_{eh}^{i\downarrow j\uparrow} & \rho_{eh}^{i\downarrow j\downarrow}\\
\hline \rho_{he}^{i\uparrow j\uparrow} & \rho_{he}^{i\uparrow j\downarrow} & \rho_{hh}^{i\uparrow j\uparrow} & \rho_{hh}^{i\uparrow j\downarrow}\\
\rho_{he}^{i\downarrow j\uparrow} & \rho_{he}^{i\downarrow j\downarrow} & \rho_{hh}^{i\downarrow j\uparrow} & \rho_{hh}^{i\downarrow j\downarrow}
\end{array}\right)\nonumber 
\end{align}

\end_inset


\end_layout

\end_inset

and relating to themselves and to each other as
