\boldsymbol{\check{H}}_{0}^{ij}= & \left(\begin{array}{cc}
\boldsymbol{H}_{0}^{ij} & 0\\
0 & -\left(\boldsymbol{H}_{0}^{ji}\right)^{T}
\end{array}\right)\\
\boldsymbol{\check{\Sigma}}^{ij}= & \left(\begin{array}{cc}
\boldsymbol{\Sigma}_{H}^{ij}+\boldsymbol{\Sigma}_{F}^{ij} & \boldsymbol{\Sigma}_{B}^{ij}\\
