.
 For this, and accounting for their spin structure, we re-express the Hartree
 term as
\begin_inset Formula 
\begin{align}
\boldsymbol{\Sigma}_{H}^{ij}= & \boldsymbol{\delta}_{ij}\sum_{\boldsymbol{\alpha}}v^{i\alpha}\rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{\alpha}}\nonumber \\
= & \delta_{ij}\sigma_{0}\sum_{\alpha}v^{i\alpha}\sum_{s_{\alpha}}\rho_{ee}^{\alpha s_{\alpha}\alpha s_{\alpha}}\nonumber \\
= & \delta_{ij}\sigma_{0}\sum_{\alpha}v^{i\alpha}\left(\rho_{ee}^{\alpha\uparrow\alpha\uparrow}+\rho_{ee}^{\alpha\downarrow\alpha\downarrow}\right)\nonumber \\
= & \delta_{ij}\sigma_{0}\sum_{\alpha}v^{i\alpha}\text{Tr}\left(\boldsymbol{\rho}_{ee}^{\alpha\alpha}\right)\label{eq:SH-2}\\
= & \delta_{ij}\sigma_{0}\sum_{\alpha}v^{i\alpha}\left[\frac{1}{2}\text{Tr}\left([\tau_{z}\otimes\sigma_{0}]\boldsymbol{\check{\rho}}^{\alpha\alpha}\right)+1\right]\\
\equiv & \frac{1}{2}\delta_{ij}\sigma_{0}\sum_{\alpha}v^{i\alpha}\text{Tr}\left([\tau_{z}\otimes\sigma_{0}]\boldsymbol{\check{\varrho}}^{\alpha\alpha}\right)
\end{align}

