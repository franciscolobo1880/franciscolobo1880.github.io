\begin_layout Plain Layout
\begin_inset Formula 
\begin{align}
\Sigma_{H}^{\boldsymbol{i}\boldsymbol{j}}= & \delta_{\boldsymbol{i}\boldsymbol{j}}\sum_{\boldsymbol{\alpha}}v^{i\alpha}\rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{\alpha}}\label{eq:SH}\\
\Sigma_{F}^{\boldsymbol{i}\boldsymbol{j}}= & -v^{ij}\rho_{ee}^{\boldsymbol{i}\boldsymbol{j}}\label{eq:SF}\\
\Sigma_{B}^{\boldsymbol{i}\boldsymbol{j}}= & v^{ij}\rho_{eh}^{\boldsymbol{i}\boldsymbol{j}}\label{eq:SB}
\end{align}

\end_inset


\end_layout

\end_inset

The interacting term of Eq.(
\begin_inset Formula $\text{\ref{eq:r}}$
\end_inset

) yield
\begin_inset Formula 
\begin{align}
 & v^{\alpha j}\left[\mathfrak{\rho}_{he}^{\boldsymbol{\alpha}\boldsymbol{j}}\mathfrak{\rho}_{eh}^{\boldsymbol{i}\boldsymbol{\alpha}}-\rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{j}}\rho_{ee}^{\boldsymbol{i}\boldsymbol{\alpha}}+\rho_{ee}^{\boldsymbol{i}\boldsymbol{j}}\rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{\alpha}}\right]\nonumber \\
= & \left\{ v^{\alpha j}\mathfrak{\rho}_{he}^{\boldsymbol{\alpha}\boldsymbol{j}}\right\} \mathfrak{\rho}_{eh}^{\boldsymbol{i}\boldsymbol{\alpha}}-\left\{ v^{\alpha j}\rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{j}}\right\} \rho_{ee}^{\boldsymbol{i}\boldsymbol{\alpha}}+\rho_{ee}^{\boldsymbol{i}\boldsymbol{j}}\left\{ v^{\alpha j}\rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{\alpha}}\right\} \nonumber \\
= & \mathfrak{\rho}_{eh}^{\boldsymbol{i}\boldsymbol{\alpha}}\left(-\Sigma_{B}^{\boldsymbol{\alpha}\boldsymbol{j}}\right)^{\dagger}+\rho_{ee}^{\boldsymbol{i}\boldsymbol{\alpha}}\Sigma_{F}^{\boldsymbol{\alpha}\boldsymbol{j}}+\rho_{ee}^{\boldsymbol{i}\boldsymbol{j}}\Sigma_{H}^{\boldsymbol{i}\boldsymbol{i}}\nonumber \\
= & \left\lceil -\boldsymbol{\mathfrak{\rho}}_{eh}^{ij}\left(-\boldsymbol{\Sigma}_{B}^{ji}\right)^{\dagger}+\boldsymbol{\rho}_{ee}^{ij}\boldsymbol{\Sigma}_{F}^{ij}+\boldsymbol{\rho}_{ee}^{ij}\boldsymbol{\Sigma}_{H}^{ij}\delta_{\boldsymbol{i}\boldsymbol{j}}\right\rceil ^{s_{i}s_{j}}\\
 & -v^{\alpha i}s\left[\mathfrak{\rho}_{he}^{\boldsymbol{\alpha}\boldsymbol{j}}\mathfrak{\rho}_{eh}^{\boldsymbol{i}\boldsymbol{\alpha}}-\rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{j}}\rho_{ee}^{\boldsymbol{i}\boldsymbol{\alpha}}+\rho_{ee}^{\boldsymbol{i}\boldsymbol{j}}\rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{\alpha}}\right]\nonumber \\
= & -\left(\mathfrak{\rho}_{he}^{\boldsymbol{\alpha}\boldsymbol{j}}\left\{ v^{i\alpha}\mathfrak{\rho}_{eh}^{\boldsymbol{i}\boldsymbol{\alpha}}\right\} +\rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{j}}\left\{ -v^{i\alpha}\rho_{ee}^{\boldsymbol{i}\boldsymbol{\alpha}}\right\} +\rho_{ee}^{\boldsymbol{i}\boldsymbol{j}}\left\{ v^{i\alpha}\rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{\alpha}}\right\} \right)\nonumber \\
= & -\left(\Sigma_{B}^{\boldsymbol{i}\boldsymbol{\alpha}}\mathfrak{\rho}_{he}^{\boldsymbol{\alpha}\boldsymbol{j}}+\Sigma_{F}^{\boldsymbol{i}\boldsymbol{\alpha}}\rho_{ee}^{\boldsymbol{\alpha}\boldsymbol{j}}+\Sigma_{H}^{\boldsymbol{i}\boldsymbol{i}}\rho_{ee}^{\boldsymbol{i}\boldsymbol{j}}\right)\nonumber \\
= & -\left\lceil \boldsymbol{\Sigma}_{B}^{ij}\boldsymbol{\mathfrak{\rho}}_{he}^{ij}+\boldsymbol{\Sigma}_{F}^{ij}\boldsymbol{\rho}_{ee}^{ij}+\boldsymbol{\rho}_{ee}^{ij}\boldsymbol{\Sigma}_{H}^{ij}\delta_{\boldsymbol{i}\boldsymbol{j}}\right\rceil ^{s_{i}s_{j}}
\end{align}

\end_inset

where 
\begin_inset Formula $\left\lceil \cdot\right\rceil ^{s_{i}s_{j}}$
\end_inset

 is the element at position 
\begin_inset Formula $s_{i}s_{j}$
\end_inset

, e.g 
\begin_inset Formula $\left\lceil M\right\rceil ^{\uparrow\uparrow}=M[1,1]$
\end_inset

.
 Putting the three pieces together, and accounting for the complete spin
 structure, the purely electronic rDM EoM yields and shown in Eq.(
\begin_inset Formula $\text{\ref{eq:ree}}$
\end_inset

).
\end_layout

\begin_layout Standard
Note that, from the relations in Eqs.(
\begin_inset Formula $\text{\ref{eq:rrs}}$
\end_inset

)-(
\begin_inset Formula $\text{\ref{eq:rrs-1}}$
\end_inset

),
\begin_inset Formula 
\begin{align}
\Sigma_{B}^{\boldsymbol{i}\boldsymbol{j}}= & \left(v^{ij}\mathfrak{\rho}_{eh}^{\boldsymbol{i}\boldsymbol{j}}\right)=v^{ij}\left(-\mathfrak{\rho}_{eh}^{\boldsymbol{j}\boldsymbol{i}}\right)=-\Sigma_{B}^{\boldsymbol{j}\boldsymbol{i}}\\
\left(\Sigma_{B}^{\boldsymbol{j}\boldsymbol{i}}\right)^{\dagger}= & \left(v^{ji}\mathfrak{\rho}_{eh}^{\boldsymbol{j}\boldsymbol{i}}\right)^{\dagger}=\left(v^{ij}\mathfrak{\rho}_{he}^{\boldsymbol{i}\boldsymbol{j}}\right)\overset{!}{=}-\left(\Sigma_{B}^{\boldsymbol{i}\boldsymbol{j}}\right)^{\dagger}
\end{align}

\end_inset

The purely electronic rDM EoM then yields
\begin_inset Formula 
\begin{align}
i\hbar\frac{d}{dt}\boldsymbol{\rho}_{ee}^{ij} & \approx\left[\boldsymbol{H}_{HF}^{ij},\boldsymbol{\rho}_{ee}^{ij}\right]+\boldsymbol{\Sigma}_{B}^{ij}\cdot\boldsymbol{\mathfrak{\rho}}_{he}^{ij}-\boldsymbol{\mathfrak{\rho}}_{eh}^{ij}\cdot\left(\boldsymbol{\Sigma}_{B}^{ji}\right)^{\dagger}\label{eq:ree}
\end{align}

\end_inset

where we have defined
\begin_inset Formula 
\begin{equation}
\boldsymbol{H}_{HF}^{ij}=\boldsymbol{H}_{0}^{ij}+\boldsymbol{\Sigma}_{H}^{ij}\delta_{\boldsymbol{i}\boldsymbol{j}}+\boldsymbol{\Sigma}_{F}^{ij}
\end{equation}

\end_inset

Analogously for the anomalous rDM EoM, we obtain 
