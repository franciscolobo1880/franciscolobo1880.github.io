\begin_inset Formula 
\begin{equation}
\boldsymbol{\check{\Sigma}}^{ij}=\frac{1}{2}\delta_{ij}\boldsymbol{\check{Q}}\sum_{\alpha}v^{i\alpha}\text{Tr}\left(\boldsymbol{\check{Q}}\boldsymbol{\check{\varrho}}^{\alpha\alpha}\right)-v^{ij}\boldsymbol{\check{Q}}\boldsymbol{\check{\varrho}}^{ij}\boldsymbol{\check{Q}}\label{eq:Sigma-1}
\end{equation}

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Subsubsection*
Alternate Nambu basis
\end_layout

\begin_layout Standard
One may define the Nambu spinor differently.
 For example, instead of 
\begin_inset Formula $\boldsymbol{\check{c}}_{i}^{\dagger}$
\end_inset

 in Eq.(
\begin_inset Formula $\text{\ref{eq:c}}$
\end_inset

), there is also common to encounter the so-called rotated basis where
\begin_inset Flex Color Box
status open

\begin_layout Plain Layout
\begin_inset Argument 1
status open

\begin_layout Plain Layout
colback=yellow!10!white, colframe=yellow!10!white, breakable
\end_layout

\end_inset


\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
vspace{-0.35cm}
\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\boldsymbol{\bar{c}}_{i}^{\dagger}=(\begin{array}{cc}
\boldsymbol{c}_{i}^{\dagger} & [i\sigma_{y}\boldsymbol{c}_{i}]\end{array})=(\begin{array}{cccc}
c_{i\uparrow}^{\dagger} & c_{i\downarrow}^{\dagger} & c_{i\downarrow} & -c_{i\uparrow}\end{array})
\end{equation}

\end_inset


\end_layout

\end_inset

These relate to the previous choice of basis as
\begin_inset Formula 
\begin{align}
\boldsymbol{\bar{c}}_{i}= & \boldsymbol{\bar{\mathcal{U}}}\boldsymbol{\check{c}}_{i}\Leftrightarrow\boldsymbol{\check{c}}_{i}=\boldsymbol{\bar{\mathcal{U}}}^{\dagger}\boldsymbol{\bar{c}}_{i}\\
\boldsymbol{\bar{c}}_{i}^{\dagger}= & \boldsymbol{\check{c}}_{i}^{\dagger}\boldsymbol{\bar{\mathcal{U}}}^{\dagger}\Leftrightarrow\boldsymbol{\check{c}}_{i}^{\dagger}=\boldsymbol{\bar{c}}_{i}^{\dagger}\boldsymbol{\bar{\mathcal{U}}}
\end{align}

\end_inset

with 
\begin_inset Formula $\bar{\boldsymbol{\mathcal{U}}}$
\end_inset

 is a unitary matrix (i.e 
\begin_inset Formula $\boldsymbol{\bar{\mathcal{U}}}^{\dagger}\boldsymbol{\bar{\mathcal{U}}}=\boldsymbol{\bar{\mathcal{U}}}\boldsymbol{\bar{\mathcal{U}}}^{\dagger}=\mathds{1}$
\end_inset

) reading
\begin_inset Formula 
\begin{equation}
\boldsymbol{\bar{\mathcal{U}}}=\left(\begin{array}{cc}
\sigma_{0} & 0\\
0 & i\sigma_{y}
\end{array}\right)=\left(\begin{array}{cc|cc}
+1 & 0 & 0 & 0\\
0 & +1 & 0 & 0\\
\hline 0 & 0 & 0 & +1\\
0 & 0 & -1 & 0
\end{array}\right)
\end{equation}

\end_inset

The rotated basis Nambu rDMs, explicitly reading
\begin_inset Formula 
\begin{align*}
\boldsymbol{\bar{\rho}}_{ij} & =\langle\boldsymbol{\bar{c}}_{j}^{\dagger}\otimes\boldsymbol{\bar{c}}_{i}\rangle\\
 & =\left(\begin{array}{cc}
\langle\boldsymbol{c}_{j}^{\dagger}\otimes\boldsymbol{c}_{i}\rangle & \langle[i\sigma_{y}\boldsymbol{c}_{j}]\otimes\boldsymbol{c}_{i}\rangle\\
\langle\boldsymbol{c}_{j}^{\dagger}\otimes[i\sigma_{y}\boldsymbol{c}_{i}]^{\dagger}\rangle & \langle[i\sigma_{y}\boldsymbol{c}_{j}]\otimes[i\sigma_{y}\boldsymbol{c}_{i}]^{\dagger}\rangle
\end{array}\right)\\
 & =\left(\begin{array}{cc|cc}
\rho_{ee}^{i\uparrow j\uparrow} & \rho_{ee}^{i\uparrow j\downarrow} & \rho_{eh}^{i\uparrow j\downarrow} & -\rho_{eh}^{i\uparrow j\uparrow}\\
\rho_{ee}^{i\downarrow j\uparrow} & \rho_{ee}^{i\downarrow j\downarrow} & \rho_{eh}^{i\downarrow j\downarrow} & -\rho_{eh}^{i\downarrow j\uparrow}\\
\hline \rho_{he}^{i\downarrow j\uparrow} & \rho_{he}^{i\downarrow j\downarrow} & \rho_{hh}^{i\downarrow j\downarrow} & -\rho_{hh}^{i\downarrow j\uparrow}\\
-\rho_{he}^{i\uparrow j\uparrow} & -\rho_{he}^{i\uparrow j\downarrow} & -\rho_{hh}^{i\uparrow j\downarrow} & \rho_{hh}^{i\uparrow j\uparrow}
\end{array}\right)
\end{align*}

\end_inset

can then be expressed also in terms of 
\begin_inset Formula $\boldsymbol{\bar{\mathcal{U}}}$
\end_inset

 as 
\begin_inset Formula 
\begin{equation}
\boldsymbol{\bar{\rho}}_{ij}=\langle\boldsymbol{\bar{c}}_{j}^{\dagger}\otimes\boldsymbol{\bar{c}}_{i}\rangle=\langle\boldsymbol{\check{c}}_{i}^{\dagger}\boldsymbol{\bar{\mathcal{U}}}^{\dagger}\otimes\boldsymbol{\bar{\mathcal{U}}}\boldsymbol{\check{c}}_{i}\rangle=\boldsymbol{\bar{\mathcal{U}}}\boldsymbol{\check{\rho}}_{ij}\boldsymbol{\bar{\mathcal{U}}}^{\dagger}
\end{equation}

\end_inset

Likewise, the matrix for the Nambu 
\begin_inset Formula $\boldsymbol{Q}$
\end_inset

 becomes 
\begin_inset Formula $\boldsymbol{\bar{Q}}=\mathcal{\boldsymbol{\bar{\mathcal{U}}}}\boldsymbol{\check{Q}}\boldsymbol{\bar{\mathcal{U}}}^{\dagger}$
\end_inset

.
 Since the last term of 
\begin_inset Formula $\boldsymbol{\check{\varrho}}$
\end_inset

 in Eq.(
\begin_inset Formula $\text{\ref{eq:varho}}$
\end_inset

) transforms into itself, then it also follows that 
\begin_inset Formula $\boldsymbol{\bar{\varrho}}=\boldsymbol{\bar{\mathcal{U}}}\boldsymbol{\check{\varrho}}\boldsymbol{\bar{\mathcal{U}}}^{\dagger}$
\end_inset

 and thus 
\begin_inset Formula $\boldsymbol{\bar{\Sigma}}^{ij}=\boldsymbol{\bar{\mathcal{U}}}\boldsymbol{\check{\Sigma}}^{ij}\boldsymbol{\bar{\mathcal{U}}}^{\dagger}$
\end_inset

 as in Eq.(
\begin_inset Formula $\text{\ref{eq:Sigma}}$
\end_inset

):
\begin_inset Formula 
\begin{equation}
\boldsymbol{\bar{\Sigma}}^{ij}=\frac{1}{2}\delta_{ij}\boldsymbol{\bar{Q}}\sum_{\alpha}v^{i\alpha}\text{Tr}\left(\boldsymbol{\bar{Q}}\boldsymbol{\bar{\varrho}}^{\alpha\alpha}\right)-v^{ij}\boldsymbol{\bar{Q}}\boldsymbol{\bar{\varrho}}^{ij}\boldsymbol{\bar{Q}}
\end{equation}

\end_inset

where we used that 
\begin_inset Formula $\boldsymbol{\bar{\mathcal{U}}}$
\end_inset

 is unitary and the cyclic property of the trace
\begin_inset Formula 
\begin{equation}
\text{Tr}\left(\boldsymbol{\bar{\mathcal{U}}}^{\dagger}\boldsymbol{\bar{Q}}\boldsymbol{\bar{\varrho}}^{\alpha\alpha}\boldsymbol{\bar{\mathcal{U}}}\right)=\text{Tr}\left(\boldsymbol{\bar{\mathcal{U}}}\boldsymbol{\bar{\mathcal{U}}}^{\dagger}\boldsymbol{\bar{Q}}\boldsymbol{\bar{\varrho}}^{\alpha\alpha}\right)=\text{Tr}\left(\boldsymbol{\bar{Q}}\boldsymbol{\bar{\varrho}}^{\alpha\alpha}\right)
\end{equation}

\end_inset

As a result of this transformation the Nambu symmetries expressed in Eq.(
\begin_inset Formula $\text{\ref{eq:N}}$
\end_inset

) become
\begin_inset Flex Color Box
status open

\begin_layout Plain Layout
\begin_inset Argument 1
status open

\begin_layout Plain Layout
colback=cyan!10!white, colframe=cyan!10!white, breakable
\end_layout

\end_inset


\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
vspace{-0.35cm}
\end_layout

\end_inset


\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
small
\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\boldsymbol{\bar{\Sigma}}^{ij}=\left(\begin{array}{cc}
\boldsymbol{\Sigma}_{H}^{ij}+\boldsymbol{\Sigma}_{F}^{ij} & -i\boldsymbol{\Sigma}_{B}^{ij}\sigma_{y}\\
\left(-i\boldsymbol{\Sigma}_{B}^{ji}\sigma_{y}\right)^{\dagger} & -\sigma_{y}\left(\boldsymbol{\Sigma}_{H}^{ji}+\boldsymbol{\Sigma}_{F}^{ji}\right)^{T}\sigma_{y}
\end{array}\right)
\end{equation}

\end_inset


\end_layout

\end_inset

Using the fact that 
\begin_inset Formula $\boldsymbol{\bar{\mathcal{U}}}$
\end_inset

 is unitary, Eq.(
\begin_inset Formula $\text{\ref{eq:Ss2}}$
\end_inset

) then becomes
\begin_inset Formula 
\begin{align*}
 & \boldsymbol{\bar{\Sigma}}^{ij}=\boldsymbol{\bar{\mathcal{U}}}\boldsymbol{\check{\Sigma}}^{ij}\boldsymbol{\bar{\mathcal{U}}}^{\dagger}\\
= & -\left[\boldsymbol{\bar{\mathcal{U}}}[\tau_{x}\otimes\sigma_{0}]\boldsymbol{\bar{\mathcal{U}}}^{\dagger}\right]\left[\boldsymbol{\bar{\mathcal{U}}}\left(\check{\boldsymbol{\Sigma}}^{ij}\right)^{*}\boldsymbol{\bar{\mathcal{U}}}^{\dagger}\right]\left[\boldsymbol{\bar{\mathcal{U}}}[\tau_{x}\otimes\sigma_{0}]\boldsymbol{\bar{\mathcal{U}}}^{\dagger}\right]\\
= & -[\tau_{y}\otimes\sigma_{y}]\left(\boldsymbol{\bar{\Sigma}}^{ij}\right)^{*}[\tau_{y}\otimes\sigma_{y}]
\end{align*}

\end_inset

where
\begin_inset Formula 
\begin{align}
 & \boldsymbol{\bar{\mathcal{U}}}[\tau_{x}\otimes\sigma_{0}]\boldsymbol{\bar{\mathcal{U}}}^{\dagger}\nonumber \\
= & \left(\begin{array}{cc}
\sigma_{0} & 0\\
0 & i\sigma_{y}
\end{array}\right)\left(\begin{array}{cc}
0 & \sigma_{0}\\
\sigma_{0} & 0
\end{array}\right)\left(\begin{array}{cc}
\sigma_{0} & 0\\
0 & -i\sigma_{y}
\end{array}\right)\nonumber \\
= & \left(\begin{array}{cc}
0 & -i\sigma_{y}\\
i\sigma_{y} & 0
\end{array}\right)=(-i\tau_{y})\otimes(i\sigma_{y})
\end{align}

\end_inset

The Nambu symmetries relations for the rotated basis read as 
\begin_inset Flex Color Box
status open

\begin_layout Plain Layout
\begin_inset Argument 1
status open

\begin_layout Plain Layout
colback=cyan!10!white, colframe=cyan!10!white, breakable
\end_layout

\end_inset


\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
vspace{-0.35cm}
\end_layout

\end_inset


\begin_inset Formula 
\begin{align}
\boldsymbol{\bar{\Sigma}}^{ij}= & \left(\boldsymbol{\bar{\Sigma}}^{ji}\right)^{\dagger}\label{eq:Ss1-1}\\
\boldsymbol{\bar{\Sigma}}^{ij}= & -[\tau_{y}\otimes\sigma_{y}]\left(\boldsymbol{\bar{\Sigma}}^{ij}\right)^{*}[\tau_{y}\otimes\sigma_{y}]\label{eq:Ss2-1}
\end{align}

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Subsection
Hubbard model
\end_layout

\begin_layout Standard
Consider, instead of the spinless potential from Eq.(
\begin_inset Formula $\text{\ref{eq:v}}$
\end_inset

), a spinful Hubbard potential
\begin_inset Flex Color Box
status open

\begin_layout Plain Layout
\begin_inset Argument 1
status open

\begin_layout Plain Layout
colback=yellow!10!white, colframe=yellow!10!white, breakable
\end_layout

\end_inset


\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
vspace{-0.4cm}
\end_layout

\end_inset


\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{equation}
v^{ij}=U\delta_{ij}
\end{equation}

\end_inset


\end_layout

\end_inset

In this model, the original non-normal-ordered interaction Hamiltonian from
 Eq.(
\begin_inset Formula $\text{\ref{eq:Hint}}$
\end_inset

) is instead
\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
small
\end_layout

\end_inset


\begin_inset Formula 
\begin{align}
H_{\text{int}}= & \frac{1}{2}\sum_{\boldsymbol{i}\boldsymbol{j}}c_{\boldsymbol{i}}^{\dagger}c_{\boldsymbol{i}}v^{ij}c_{\boldsymbol{j}}^{\dagger}c_{\boldsymbol{j}}-\frac{1}{2}\sum_{\boldsymbol{i}}c_{\boldsymbol{i}}^{\dagger}c_{\boldsymbol{i}}v^{ii}\nonumber \\
= & \frac{1}{2}\sum_{is_{i}}\sum_{is_{j}}c_{is_{i}}^{\dagger}c_{is_{i}}\left\{ U\delta_{ij}\right\} c_{js_{j}}^{\dagger}c_{js_{j}}-\frac{1}{2}\sum_{is_{i}}c_{is_{i}}^{\dagger}c_{is_{i}}\left\{ U\delta_{ii}\right\} \nonumber \\
= & \frac{1}{2}U\sum_{is_{i}}\left[\left(c_{is_{i}}^{\dagger}c_{is_{i}}n_{i\uparrow}+c_{is_{i}}^{\dagger}c_{is_{i}}n_{i\downarrow}\right)-\left(n_{i\uparrow}+n_{i\downarrow}\right)\delta_{ii}\right]\nonumber \\
= & \frac{1}{2}U\sum_{i}\left(n_{i\uparrow}n_{i\downarrow}+n_{i\downarrow}n_{i\uparrow}\right)
\end{align}

\end_inset


\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
normalsize
\end_layout

\end_inset

 where 
\begin_inset Formula $n_{is_{i}}=c_{is_{i}}^{\dagger}c_{is_{i}}$
\end_inset

 is the number operator and 
\begin_inset Formula 
\begin{equation}
(n_{i\uparrow}n_{i\uparrow}-n_{i\uparrow}\delta_{ii})+(n_{i\downarrow}n_{i\downarrow}-n_{i\downarrow}\delta_{ii})=0
\end{equation}

\end_inset

 because 
\begin_inset Formula $n_{is_{i}}n_{is_{i}}=(n_{is_{i}})^{2}=n_{is_{i}}$
\end_inset

 (there is or there is not an electron at site 
\begin_inset Formula $i$
\end_inset

 and spin 
\begin_inset Formula $s_{i}$
\end_inset

, i.e 
\begin_inset Formula $n_{is_{i}}=0\text{ or }1$
\end_inset

).
 Using that
\begin_inset Formula 
\begin{align}
n_{is_{i}}n_{i\bar{s_{i}}} & =c_{is_{i}}^{\dagger}\left\{ c_{is_{i}}c_{i\bar{s_{i}}}^{\dagger}\right\} c_{i\bar{s_{i}}}=c_{is_{i}}^{\dagger}\left(\delta_{ii}\cancelto{0}{\delta_{s_{i}\bar{s_{i}}}}-c_{i\bar{s_{i}}}^{\dagger}c_{is_{i}}\right)c_{i\bar{s_{i}}}\nonumber \\
 & =-\left\{ c_{is_{i}}^{\dagger}c_{i\bar{s_{i}}}^{\dagger}\right\} \left\{ c_{is_{i}}c_{i\bar{s_{i}}}\right\} =-c_{i\bar{s_{i}}}^{\dagger}\left\{ c_{is_{i}}^{\dagger}c_{i\bar{s_{i}}}\right\} c_{is_{i}}\nonumber \\
 & =n_{i\bar{s_{i}}}n_{is_{i}},
\end{align}

\end_inset

one can simply write 
\begin_inset Formula 
\begin{equation}
H_{\text{int}}\rightarrow H_{U}=U\sum_{i}n_{i\uparrow}n_{i\downarrow}
\end{equation}

\end_inset

Also, see that by definition of the model, spurious interaction do not take
 part so there is no need to subtracting them preemptively.
 The Nambu self-energy term then reads
\begin_inset Flex Color Box
status open

\begin_layout Plain Layout
\begin_inset Argument 1
status open

\begin_layout Plain Layout
colback=cyan!10!white, colframe=cyan!10!white, breakable
\end_layout

\end_inset


\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
vspace{-0.35cm}
\end_layout

\end_inset


\begin_inset Formula 
\begin{align}
\boldsymbol{\check{\Sigma}}_{U}^{ij}= & U\delta_{ij}\left(\frac{1}{2}[\tau_{z}\otimes\sigma_{0}]\text{Tr}\left([\tau_{z}\otimes\sigma_{0}]\boldsymbol{\check{\varrho}}^{ii}\right)\right.\nonumber \\
 & \qquad\left.\phantom{\frac{1}{2}}-[\tau_{z}\otimes\sigma_{0}]\boldsymbol{\check{\varrho}}^{ij}[\tau_{z}\otimes\sigma_{0}]\right)
\end{align}

\end_inset


\end_layout

\end_inset


\end_layout

