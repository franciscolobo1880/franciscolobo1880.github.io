\begin_layout Standard
The Oreg-Lutchyn Majorana minimal model consists of a finite 1D semiconductor
 nanowire with strong spin-orbit coupling (SOC) 
\begin_inset Formula $\alpha$
\end_inset

 and a tunable chemical potential 
\begin_inset Formula $\mu$
\end_inset

, in proximity of a superconductor of homogeneous pairing 
\begin_inset Formula $\Delta$
\end_inset

, having a magnetic field 
\begin_inset Formula $B$
\end_inset

 applied along it's length, defined as the 
\begin_inset Formula $\boldsymbol{\hat{z}}$
\end_inset

 direction.
 The Hamiltonian describing this system can then be decomposed as
\begin_inset Formula 
\begin{align}
H & =H_{K}+H_{SOC}+H_{Z}+H_{SC}\label{eq:HOL}\\
H_{K} & =\sum_{s}c_{s}^{\dagger}(z)\left(-\eta\partial_{z}^{2}-\mu\right)c_{s}(z)\\
H_{SOC} & =\boldsymbol{c}^{\dagger}(z)\left(i\alpha\sigma_{y}\partial_{z}\right)\boldsymbol{c}(z)\\
H_{Z} & =\boldsymbol{c}^{\dagger}(z)\left(V_{Z}\sigma_{z}\right)\boldsymbol{c}(z)\\
H_{SC} & =\frac{1}{2}\Delta c_{\uparrow}^{\dagger}(z)c_{\downarrow}(z)+\text{h.c.}
\end{align}

\end_inset

where 
\begin_inset Formula $c/c^{\dagger}$
\end_inset

 are fermion operators and 
\begin_inset Formula $s=\uparrow,\text{\ensuremath{\downarrow}}$
\end_inset

 spin indices such that
\begin_inset Formula 
\[
\boldsymbol{c}^{\dagger}=\left(\begin{array}{cc}
c_{\uparrow}^{\dagger} & c_{i}\end{array}\right)\text{ and }\check{c}_{i}=\left(\begin{array}{c}
c_{i}\\
c_{i}^{\dagger}
\end{array}\right)
\]

\end_inset

and 
\begin_inset Formula $\eta=\nicefrac{\hbar²}{2m^{*}}$
\end_inset

with 
\begin_inset Formula $m^{*}$
\end_inset

 the effective mass of the electrons, 
\begin_inset Formula $V_{Z}=g_{J}\mu_{B}B/2$
\end_inset

, the Zeeman potential with 
\begin_inset Formula $g_{J}$
\end_inset

 the Landé gyromagnetic moment and 
\begin_inset Formula $\mu_{B}$
\end_inset

 Bohr's magneton.
 
\end_layout

