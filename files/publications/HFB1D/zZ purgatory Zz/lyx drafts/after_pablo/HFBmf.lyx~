\begin_layout Subsection
Nambu mean-field Hamiltonian
\end_layout

\begin_layout Standard
We start by solving for the purely electronic rDM equation of motions in
 the Heisenberg picture of quantum mechanics, where the fermionic operators
 evolve accordingly to the Heisenberg equation.
 We have
\begin_inset Formula 
\begin{align}
\frac{d}{dt}\rho_{ee}^{\boldsymbol{i}\boldsymbol{j}} & =\frac{i}{\hbar}\left\langle \left[H,c_{\boldsymbol{j}}^{\dagger}\right]c_{\boldsymbol{i}}\right\rangle +\frac{i}{\hbar}\left\langle c_{\boldsymbol{j}}^{\dagger}\left[H,c_{\boldsymbol{i}}\right]\right\rangle 
\end{align}

\end_inset

with 
\begin_inset Formula $H$
\end_inset

 the Hamiltonian in Eq.(
\begin_inset Formula $\text{\ref{eq:H-1}}$
\end_inset

).
 The time dependency in the fermionic operators is being omitted for compactness.
 
\end_layout

\begin_layout Standard
Making use of the fermionic anti-commutator properties, these commutators
 read, respectively,
\begin_inset Formula 
\begin{align*}
[H,c_{\boldsymbol{j}}^{\dagger}]= & \sum_{\boldsymbol{\alpha}\boldsymbol{\beta}}H_{0}^{\boldsymbol{\alpha}\boldsymbol{\beta}}\left[c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\beta}},c_{\boldsymbol{j}}^{\dagger}\right]+\frac{1}{2}\sum_{\boldsymbol{\alpha}\boldsymbol{\beta}}v^{\alpha\beta}\left[c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\beta}}^{\dagger}c_{\boldsymbol{\beta}}c_{\boldsymbol{\alpha}},c_{\boldsymbol{j}}^{\dagger}\right]\\{}
[H,c_{\boldsymbol{i}}]= & \sum_{\boldsymbol{\alpha}\boldsymbol{\beta}}H_{0}^{\boldsymbol{\alpha}\boldsymbol{\beta}}\left[c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\beta}},c_{\boldsymbol{i}}\right]+\frac{1}{2}\sum_{\boldsymbol{\alpha}\boldsymbol{\beta}}v^{\alpha\beta}\left[c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\beta}}^{\dagger}c_{\boldsymbol{\beta}}c_{\boldsymbol{\alpha}},c_{\boldsymbol{i}}\right]
\end{align*}

\end_inset

The commutators reading
\begin_inset Formula 
\begin{align}
\left[c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\beta}},c_{j}^{\dagger}\right]= & c_{\boldsymbol{\alpha}}^{\dagger}\delta_{\boldsymbol{\beta}\boldsymbol{j}}\\
\left[c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\beta}},c_{\boldsymbol{i}}\right]= & -c_{\boldsymbol{\beta}}\delta_{\boldsymbol{i}\boldsymbol{\alpha}}\\
\left[c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\beta}}^{\dagger}c_{\boldsymbol{\beta}}c_{\boldsymbol{\alpha}},c_{\boldsymbol{j}}^{\dagger}\right]= & c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\beta}}^{\dagger}c_{\boldsymbol{\beta}}\delta_{\boldsymbol{\alpha}\boldsymbol{j}}-c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\beta}}^{\dagger}c_{\boldsymbol{\alpha}}\delta_{\boldsymbol{\beta}\boldsymbol{j}}\\
\left[c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\beta}}^{\dagger}c_{\boldsymbol{\beta}}c_{\boldsymbol{\alpha}},c_{\boldsymbol{i}}\right]= & c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{\beta}}c_{\boldsymbol{\alpha}}\delta_{\boldsymbol{\beta}\boldsymbol{i}}-c_{\boldsymbol{\beta}}^{\dagger}c_{\boldsymbol{\beta}}c_{\boldsymbol{\alpha}}\delta_{\boldsymbol{i}\boldsymbol{\alpha}}
\end{align}

\end_inset

where we used that
\begin_inset Formula 
\begin{align}
\left[AB,Z\right]= & A\left\{ B,Z\right\} -\left\{ Z,A\right\} B\\
\left[ABCD,Z\right]= & AB\left(C\left\{ D,Z\right\} -\left\{ Z,C\right\} D\right)\nonumber \\
 & +\left(A\left\{ B,Z\right\} -\left\{ Z,A\right\} B\right)CD
\end{align}

\end_inset

The complete Heisenberg commutators then yield
\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
small
\end_layout

\end_inset


\begin_inset Formula 
\begin{align}
[H,c_{\boldsymbol{j}}^{\dagger}] & =\sum_{\boldsymbol{\alpha}}H_{0}^{\boldsymbol{\alpha}\boldsymbol{j}}c_{\boldsymbol{\alpha}}^{\dagger}+\frac{1}{2}\sum_{\boldsymbol{\beta}}v^{j\beta}c_{\boldsymbol{j}}^{\dagger}c_{\boldsymbol{\beta}}^{\dagger}c_{\boldsymbol{\beta}}-\frac{1}{2}\sum_{\boldsymbol{\alpha}}v^{\alpha j}c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{j}}^{\dagger}c_{\boldsymbol{\alpha}}\nonumber \\
 & =\sum_{\boldsymbol{\alpha}}H_{0}^{\boldsymbol{\alpha}\boldsymbol{j}}c_{\boldsymbol{\alpha}}^{\dagger}+\frac{1}{2}\sum_{\boldsymbol{\alpha}}v^{\alpha j}\left(c_{\boldsymbol{j}}^{\dagger}c_{\boldsymbol{\alpha}}^{\dagger}-c_{\boldsymbol{\alpha}}^{\dagger}c_{\boldsymbol{j}}^{\dagger}\right)c_{\boldsymbol{\alpha}}\label{eq:Hcj}\\{}
