\begin_inset Formula 
\[
\sigma_{i}\Psi_{\alpha}\rightarrow\left(\tau_{0}\otimes\sigma_{i}\right)\Psi_{\alpha}=\left(\begin{array}{c}
\sigma_{i}\left[\begin{array}{c}
\psi_{\tilde{\alpha}\uparrow}\\
\psi_{\tilde{\alpha}\downarrow}
\end{array}\right]\\
\sigma_{i}\left[\begin{array}{c}
\psi_{\tilde{\alpha}\downarrow}^{*}\\
-\psi_{\tilde{\alpha}\uparrow}^{*}
\end{array}\right]
\end{array}\right)\quad\text{and}\quad\tau_{i}\Psi_{\alpha}\rightarrow\left(\tau_{i}\otimes\sigma_{0}\right)\Psi_{\alpha}=\tau_{i}\left(\begin{array}{c}
\psi_{\alpha}\\
\psi_{\alpha}^{\dagger}
\end{array}\right)
\]

\end_inset

So, for example, for the spin-orbit coupling term, we have that 
\begin_inset Formula $\sigma_{y}\tau_{z}\rightarrow\tau_{z}\otimes\sigma_{y}$
\end_inset

.
 By design, the spin space portion of it is already written in terms of
 
\begin_inset Formula $\Psi$
\end_inset

 in the respective base and thus is trivially dealt it.
 We just need to concern ourselves with the e-h space.
 The normal term will read along the lines of 
\begin_inset Formula 
\begin{align*}
\psi_{\alpha}^{\dagger}\psi_{\beta} & =\frac{1}{2}\psi_{\alpha}^{\dagger}\psi_{\beta}+\frac{1}{2}\psi_{\alpha}^{\dagger}\psi_{\beta}=\frac{1}{2}\psi_{\alpha}^{\dagger}\psi_{\beta}-\frac{1}{2}\psi_{\beta}\psi_{\alpha}^{\dagger}=\frac{1}{2}\left(\psi_{\alpha}^{\dagger}\,\psi_{\alpha}\right)\left(\begin{array}{cc}
1 & 0\\
0 & -1
\end{array}\right)\left(\begin{array}{c}
\psi_{\beta}\\
\psi_{\beta}^{\dagger}
\end{array}\right)=\frac{1}{2}\Psi_{\alpha}\tau_{z}\Psi_{\beta}
\end{align*}

\end_inset

 and the anomalous term in the lines of
\begin_inset Formula 
\begin{align*}
 & \frac{1}{2}\Delta_{\alpha\beta}\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}+\frac{1}{2}\Delta_{\alpha\beta}^{*}\psi_{\beta}\psi_{\alpha}\\
= & \frac{1}{2}\left(\Theta+e^{i\varphi}\Theta^{\prime}\right)\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}+\frac{1}{2}\left(\Theta+e^{-i\varphi}\Theta^{\prime}\right)\psi_{\beta}\psi_{\alpha}\\
= & \Theta\left(\frac{1}{2}\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}+\frac{1}{2}\psi_{\beta}\psi_{\alpha}\right)+\frac{1}{2}\Theta^{\prime}\left(e^{i\varphi}\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}+e^{-i\varphi}\psi_{\beta}\psi_{\alpha}\right)
\end{align*}

\end_inset

The first of these terms immediately read as
\begin_inset Formula 
\begin{align*}
\frac{1}{2}\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}+\frac{1}{2}\psi_{\beta}\psi_{\alpha} & =\frac{1}{2}\left(\psi_{\alpha}^{\dagger}\,\psi_{\alpha}\right)\left(\begin{array}{cc}
0 & 1\\
1 & 0
\end{array}\right)\left(\begin{array}{c}
\psi_{\beta}\\
\psi_{\beta}^{\dagger}
\end{array}\right)=\frac{1}{2}\Psi_{\alpha}\tau_{x}\Psi_{\beta}
\end{align*}

\end_inset

The remaining terms continues as
\begin_inset Formula 
\begin{align*}
 & \frac{1}{2}\Theta^{\prime}\left(e^{i\varphi}\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}+e^{-i\varphi}\psi_{\beta}\psi_{\alpha}\right)\\
= & +\frac{1}{4}\Theta^{\prime}\left[e^{i\varphi}\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}+e^{-i\varphi}\psi_{\beta}\psi_{\alpha}+\left\{ e^{-i\varphi}\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}+e^{i\varphi}\psi_{\beta}\psi_{\alpha}\right\} \right]\\
 & +\frac{1}{4}\Theta^{\prime}\left[e^{i\varphi}\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}+e^{-i\varphi}\psi_{\beta}\psi_{\alpha}-\left\{ e^{-i\varphi}\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}+e^{i\varphi}\psi_{\beta}\psi_{\alpha}\right\} \right]\\
= & \Theta^{\prime}\left(\frac{e^{i\varphi}+e^{-i\varphi}}{2}\left(\frac{1}{2}\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}+\frac{1}{2}\psi_{\beta}\psi_{\alpha}\right)-\frac{e^{i\varphi}-e^{-i\varphi}}{2i}\left(-\frac{1}{2}i\psi_{\alpha}^{\dagger}\psi_{\beta}^{\dagger}+\frac{1}{2}i\psi_{\beta}\psi_{\alpha}\right)\right)\\
= & \frac{1}{2}\Psi_{\alpha}\left[\Theta^{\prime}\left(\cos(\varphi)\tau_{x}-\sin(\varphi)\tau_{y}\right)\right]\Psi_{\beta}
\end{align*}

\end_inset


